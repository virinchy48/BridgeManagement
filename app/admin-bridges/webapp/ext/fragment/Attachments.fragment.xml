<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:unified="sap.ui.unified"
  core:require="{Attachments: 'BridgeManagement/adminbridges/ext/controller/Attachments'}">
  <VBox
    id="attachmentsHost"
    busy="{attachments>/busy}"
    modelContextChange="Attachments.onContextChange"
    class="sapUiSmallMargin">
    <OverflowToolbar>
      <Title text="Attachments" level="H3"/>
      <ToolbarSpacer/>
      <Button
        icon="sap-icon://refresh"
        type="Transparent"
        tooltip="Refresh attachments"
        press="Attachments.onRefresh"/>
      <unified:FileUploader
        id="bridgeAttachmentUploader"
        buttonOnly="true"
        buttonText="Upload"
        icon="sap-icon://upload"
        sameFilenameAllowed="true"
        change="Attachments.onFileChange"/>
    </OverflowToolbar>
    <Table
      id="bridgeAttachmentsTable"
      items="{attachments>/items}"
      noDataText="No attachments uploaded"
      growing="true"
      growingThreshold="20">
      <columns>
        <Column>
          <Text text="File Name"/>
        </Column>
        <Column width="12rem">
          <Text text="Type"/>
        </Column>
        <Column width="8rem" hAlign="End">
          <Text text="Size"/>
        </Column>
        <Column width="12rem">
          <Text text="Uploaded"/>
        </Column>
        <Column width="8rem" hAlign="End">
          <Text text="Actions"/>
        </Column>
      </columns>
      <items>
        <ColumnListItem>
          <cells>
            <ObjectIdentifier title="{attachments>fileName}" text="{attachments>title}"/>
            <Text text="{attachments>mediaType}" wrapping="false"/>
            <Text text="{attachments>fileSizeText}" textAlign="End"/>
            <Text text="{attachments>createdAtText}" wrapping="false"/>
            <HBox justifyContent="End">
              <Button
                icon="sap-icon://display"
                type="Transparent"
                tooltip="Open"
                press="Attachments.onOpen"/>
              <Button
                icon="sap-icon://download"
                type="Transparent"
                tooltip="Download"
                press="Attachments.onDownload"/>
              <Button
                icon="sap-icon://delete"
                type="Transparent"
                tooltip="Delete"
                press="Attachments.onDelete"/>
            </HBox>
          </cells>
        </ColumnListItem>
      </items>
    </Table>
  </VBox>
</core:FragmentDefinition>
