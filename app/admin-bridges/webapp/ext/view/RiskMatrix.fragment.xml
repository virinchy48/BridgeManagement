<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout">

  <Dialog
    id="riskMatrixDialog"
    title="{matrix>/title}"
    contentWidth="520px"
    resizable="true"
    draggable="true">

    <content>
      <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

        <IconTabBar
          id="riskMatrixTabBar"
          select=".onRiskMatrixTabSelect"
          expandable="false">
          <items>
            <IconTabFilter
              id="inherentTab"
              key="inherent"
              text="Inherent Risk">
              <content>
                <core:HTML id="inherentMatrixHtml" content="{matrix>/inherentHtml}" />
              </content>
            </IconTabFilter>
            <IconTabFilter
              id="residualTab"
              key="residual"
              text="Residual Risk">
              <content>
                <core:HTML id="residualMatrixHtml" content="{matrix>/residualHtml}" />
              </content>
            </IconTabFilter>
          </items>
        </IconTabBar>

        <HBox class="sapUiTinyMarginTop" alignItems="Center">
          <items>
            <Text text="Selected: " class="sapUiTinyMarginEnd" />
            <ObjectStatus
              text="{matrix>/selectedLabel}"
              state="{matrix>/selectedState}"
              inverted="true" />
          </items>
        </HBox>

        <Text
          text="Click a cell to select likelihood (row) and consequence (column)."
          class="sapUiTinyMarginTop"
          wrapping="true" />

        <l:HorizontalLayout class="sapUiSmallMarginTop">
          <HBox wrap="Wrap" alignItems="Center">
            <items>
              <HBox class="sapUiTinyMarginEnd" alignItems="Center">
                <items>
                  <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#4CAF50;border-radius:2px;margin-right:4px;'&gt;&lt;/span&gt;" />
                  <Text text="Low (≤4)" />
                </items>
              </HBox>
              <HBox class="sapUiTinyMarginEnd sapUiSmallMarginBegin" alignItems="Center">
                <items>
                  <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#FF9800;border-radius:2px;margin-right:4px;'&gt;&lt;/span&gt;" />
                  <Text text="Medium (5–9)" />
                </items>
              </HBox>
              <HBox class="sapUiTinyMarginEnd sapUiSmallMarginBegin" alignItems="Center">
                <items>
                  <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#FF5722;border-radius:2px;margin-right:4px;'&gt;&lt;/span&gt;" />
                  <Text text="High (10–14)" />
                </items>
              </HBox>
              <HBox class="sapUiSmallMarginBegin" alignItems="Center">
                <items>
                  <core:HTML content="&lt;span style='display:inline-block;width:14px;height:14px;background:#F44336;border-radius:2px;margin-right:4px;'&gt;&lt;/span&gt;" />
                  <Text text="Extreme (≥15)" />
                </items>
              </HBox>
            </items>
          </HBox>
        </l:HorizontalLayout>

      </VBox>
    </content>

    <beginButton>
      <Button
        text="Apply"
        type="Emphasized"
        press=".onRiskMatrixApply" />
    </beginButton>
    <endButton>
      <Button
        text="Cancel"
        press=".onRiskMatrixCancel" />
    </endButton>

  </Dialog>

</core:FragmentDefinition>
