                      "enabled": true,
                      "requiresSelection": false,
                      "type": "Emphasized"
                    },
                    "createWorkOrderAction": {
                      "text": "Create Work Order",
                      "press": "BridgeManagement.adminbridges.ext.controller.BridgeDetailExt.onCreateWorkOrder",
