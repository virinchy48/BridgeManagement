                { "id": "Inspections",          "tileType": "sap.ushell.ui.tile.StaticTile", "properties": { "title": "Inspections",            "subtitle": "All Bridge Inspections",       "icon": "sap-icon://inspection",                  "targetURL": "#Bridges-manage&/BridgeInspections" } },
                { "id": "Defects",              "tileType": "sap.ushell.ui.tile.StaticTile", "properties": { "title": "Defects",                "subtitle": "View-Only — Create via Inspections", "icon": "sap-icon://error",                       "targetURL": "#Bridges-manage&/BridgeDefects" } },
                { "id": "Capacity",             "tileType": "sap.ushell.ui.tile.StaticTile", "properties": { "title": "Bridge Capacity",         "subtitle": "Load & Geometric Capacity",    "icon": "sap-icon://weight",                      "targetURL": "#Bridges-manage&/BridgeCapacities" } },
                { "id": "ConditionSurveys",     "tileType": "sap.ushell.ui.tile.StaticTile", "properties": { "title": "Condition Surveys",      "subtitle": "Physical Condition Ratings",   "icon": "sap-icon://survey",                      "targetURL": "#Bridges-manage&/BridgeConditionSurveys" } },
                { "id": "LoadRatings",          "tileType": "sap.ushell.ui.tile.StaticTile", "properties": { "title": "Load Ratings",           "subtitle": "Per-Vehicle Class Ratings",    "icon": "sap-icon://vehicle-repair",              "targetURL": "#Bridges-manage&/BridgeLoadRatings" } },
