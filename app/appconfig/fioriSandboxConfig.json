                    "title": "Mass Upload",
                    "subtitle": "CSV Drag & Drop",
                    "icon": "sap-icon://upload-to-cloud",
                    "targetURL": "#MassUpload-display"
                  }
                },
                {
                  "id": "BmsAdmin",
                  "tileType": "sap.ushell.ui.tile.StaticTile",
                  "properties": {
                    "title": "BMS Administration",
                    "subtitle": "Audit, Config & User Access",
                    "icon": "sap-icon://action-settings",
                    "targetURL": "#BmsAdmin-manage"
                  }
                },
                {
                  "id": "MassEdit",
                  "tileType": "sap.ushell.ui.tile.StaticTile",
                  "properties": {
                    "title": "Mass Edit",
                    "subtitle": "In-App Grid Editor",
                    "icon": "sap-icon://edit",
                    "targetURL": "#MassEdit-manage"
                  }
                }
              ]
            }
          ]
        }
      }
