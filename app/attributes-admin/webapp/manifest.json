{
  "_version": "1.8.0",
  "sap.app": {
    "id": "BridgeManagement.attributesadmin",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "AdminService": {
        "uri": "/odata/v4/admin/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "AttributesAdmin-manage": {
          "signature": { "parameters": {}, "additionalParameters": "allowed" },
          "semanticObject": "AttributesAdmin",
          "action": "manage",
          "title": "{{appTitle}}",
          "subTitle": "{{appSubTitle}}",
          "icon": "sap-icon://settings"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": { "sap.m": {}, "sap.ui.core": {}, "sap.ui.layout": {}, "sap.f": {} }
    },
    "models": {
      "i18n": { "type": "sap.ui.model.resource.ResourceModel", "uri": "i18n/i18n.properties" }
    },
    "rootView": {
      "viewName": "BridgeManagement.attributesadmin.view.AttributesAdmin",
      "type": "XML",
      "async": true,
      "id": "AttributesAdmin"
    },
    "contentDensities": { "compact": true, "cozy": false }
  },
  "sap.fiori": { "registrationIds": [], "archeType": "transactional" }
}
