<mvc:View
  controllerName="BridgeManagement.auditreport.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:t="sap.ui.table"
  displayBlock="true">

  <App id="auditApp">
    <Page
      id="auditPage"
      title="Change Document Report"
      showHeader="true"
      class="sapUiResponsivePadding--header">

      <customHeader>
        <Bar>
          <contentLeft>
            <Title text="Change Document Report" level="H2" />
          </contentLeft>
          <contentRight>
            <Button icon="sap-icon://download" text="Export CSV" press=".onExportCsv" type="Transparent" />
            <Button icon="sap-icon://refresh" text="Refresh" press=".onRefresh" type="Transparent" />
          </contentRight>
        </Bar>
      </customHeader>

      <!-- KPI summary strip -->
      <content>
        <VBox class="sapUiSmallMargin">

          <!-- Filter Panel -->
          <Panel headerText="Search &amp; Filter" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
            <content>
              <f:SimpleForm layout="ColumnLayout" columnsM="2" columnsL="3" columnsXL="4" editable="true">
                <f:content>
                  <Label text="Object Type" />
                  <Select id="filterObjectType" change=".onFilterChange" width="100%">
                    <items>
                      <core:Item key="" text="All Types" xmlns:core="sap.ui.core" />
                      <core:Item key="Bridge" text="Bridge" xmlns:core="sap.ui.core" />
                      <core:Item key="Restriction" text="Restriction" xmlns:core="sap.ui.core" />
                      <core:Item key="GISConfig" text="GIS Config" xmlns:core="sap.ui.core" />
                      <core:Item key="Lookup" text="Lookup / Code List" xmlns:core="sap.ui.core" />
                    </items>
                  </Select>

                  <Label text="Change Source" />
                  <Select id="filterSource" change=".onFilterChange" width="100%">
                    <items>
                      <core:Item key="" text="All Sources" xmlns:core="sap.ui.core" />
                      <core:Item key="OData" text="OData (Fiori UI)" xmlns:core="sap.ui.core" />
                      <core:Item key="MassEdit" text="Mass Edit" xmlns:core="sap.ui.core" />
                      <core:Item key="MassUpload" text="Mass Upload" xmlns:core="sap.ui.core" />
                    </items>
                  </Select>

                  <Label text="Changed By (User)" />
                  <Input id="filterUser" placeholder="Enter user name or ID" liveChange=".onFilterChange" width="100%" />

                  <Label text="Object Name / ID" />
                  <Input id="filterObjectId" placeholder="Bridge name, restriction ref…" liveChange=".onFilterChange" width="100%" />

                  <Label text="From Date" />
                  <DatePicker id="filterDateFrom" change=".onFilterChange" valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy" width="100%" />

                  <Label text="To Date" />
                  <DatePicker id="filterDateTo" change=".onFilterChange" valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy" width="100%" />
                </f:content>
              </f:SimpleForm>
              <HBox justifyContent="End" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
                <Button text="Apply Filters" press=".onApplyFilters" type="Emphasized" />
                <Button text="Reset" press=".onResetFilters" type="Transparent" class="sapUiSmallMarginBegin" />
              </HBox>
            </content>
          </Panel>

          <!-- Summary KPI tiles -->
          <HBox id="kpiBox" wrap="Wrap" class="sapUiSmallMarginBottom" visible="false">
            <GenericTile id="kpiTotal" header="Total Changes" class="sapUiSmallMarginEnd sapUiSmallMarginBottom" tileContent-grow="1">
              <tileContent>
                <TileContent>
                  <content>
                    <NumericContent id="kpiTotalVal" value="0" scale="" withMargin="false" />
                  </content>
                </TileContent>
              </tileContent>
            </GenericTile>
          </HBox>

          <!-- Object group list -->
          <Panel id="resultsPanel" headerText="Change Document" expandable="false" visible="false">
            <headerToolbar>
              <Toolbar>
                <Title id="resultsTitle" text="Changes" level="H3" />
                <ToolbarSpacer />
                <Text id="recordCount" text="" />
              </Toolbar>
            </headerToolbar>
            <content>
              <!-- Group-by-object tree: outer list of objects, inner table of field changes -->
              <List id="objectGroupList" mode="None" noDataText="No changes found for the selected filters."
                    growing="true" growingThreshold="50" growingScrollToLoad="true">
                <items>
                  <CustomListItem>
                    <VBox />
                  </CustomListItem>
                </items>
              </List>
            </content>
          </Panel>

          <!-- Flat change table (rendered dynamically) -->
          <Panel id="flatTablePanel" visible="false" headerText="All Field Changes" expandable="true" expanded="true">
            <headerToolbar>
              <Toolbar>
                <Title text="Field-Level Changes" level="H3" />
                <ToolbarSpacer />
                <Text id="flatCount" text="" />
              </Toolbar>
            </headerToolbar>
            <content>
              <t:Table id="changeTable" visibleRowCount="20" selectionMode="None"
                       rowSelectionChange=".onRowSelect" enableBusyIndicator="true"
                       noData="No changes match the current filters.">
                <t:columns>
                  <t:Column width="160px">
                    <Label text="Changed At" />
                    <t:template><Text text="{changedAtDisplay}" wrapping="false" /></t:template>
                  </t:Column>
                  <t:Column width="120px">
                    <Label text="Changed By" />
                    <t:template><Text text="{changedBy}" wrapping="false" /></t:template>
                  </t:Column>
                  <t:Column width="100px">
                    <Label text="Object Type" />
                    <t:template>
                      <ObjectStatus text="{objectType}" state="{objectTypeState}" />
                    </t:template>
                  </t:Column>
                  <t:Column width="180px">
                    <Label text="Object Name" />
                    <t:template><Text text="{objectName}" wrapping="false" /></t:template>
                  </t:Column>
                  <t:Column width="160px">
                    <Label text="Field" />
                    <t:template><Text text="{fieldName}" wrapping="false" /></t:template>
                  </t:Column>
                  <t:Column width="200px">
                    <Label text="Old Value" />
                    <t:template>
                      <Text text="{oldValue}" wrapping="false">
                        <customData>
                          <core:CustomData xmlns:core="sap.ui.core" key="style" value="color:#c0392b" />
                        </customData>
                      </Text>
                    </t:template>
                  </t:Column>
                  <t:Column width="200px">
                    <Label text="New Value" />
                    <t:template>
                      <Text text="{newValue}" wrapping="false">
                        <customData>
                          <core:CustomData xmlns:core="sap.ui.core" key="style" value="color:#27ae60" />
                        </customData>
                      </Text>
                    </t:template>
                  </t:Column>
                  <t:Column width="100px">
                    <Label text="Source" />
                    <t:template>
                      <ObjectStatus text="{changeSource}" state="{sourceState}" />
                    </t:template>
                  </t:Column>
                </t:columns>
              </t:Table>
            </content>
          </Panel>

          <!-- Empty state -->
          <VBox id="emptyState" alignItems="Center" justifyContent="Center" class="sapUiLargeMargin">
            <core:Icon xmlns:core="sap.ui.core" src="sap-icon://history" size="5rem" color="var(--sapNeutralColor)" />
            <Title text="Apply filters to view change documents" level="H4" class="sapUiSmallMarginTop" />
            <Text text="Select object type, date range, or user and click Apply Filters." />
          </VBox>

        </VBox>
      </content>
    </Page>
  </App>
</mvc:View>
