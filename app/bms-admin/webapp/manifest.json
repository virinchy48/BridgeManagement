{
  "_version": "1.8.0",
  "sap.app": {
    "id": "BridgeManagement.bmsadmin",
    "type": "application",
    "title": "BMS Administration",
    "description": "Bridge Management System Administration",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.0.0" },
    "crossNavigation": {
      "inbounds": {
        "BmsAdmin-manage": {
          "signature": { "parameters": {}, "additionalParameters": "allowed" },
          "semanticObject": "BmsAdmin",
          "action": "manage",
          "title": "BMS Administration",
          "info": "Manage reference data, audit logs, data quality, user access, system config and integrations",
          "icon": "sap-icon://action-settings"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "deviceTypes": { "desktop": true, "phone": false, "tablet": true }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.tnt": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.ui.table": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "rootView": {
      "viewName": "BridgeManagement.bmsadmin.view.Shell",
      "type": "XML",
      "id": "bmsAdminShell"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "BridgeManagement.bmsadmin.view",
        "controlId": "adminNavContainer",
        "controlAggregation": "pages",
        "bypassed": { "target": "changeDocuments" }
      },
      "routes": [
        { "pattern": "", "name": "home", "target": "changeDocuments" },
        { "pattern": "change-documents", "name": "changeDocuments", "target": "changeDocuments" },
        { "pattern": "data-quality",       "name": "dataQuality",       "target": "dataQuality" },
        { "pattern": "user-access", "name": "userAccess", "target": "userAccess" },
        { "pattern": "system-config", "name": "systemConfig", "target": "systemConfig" },
        { "pattern": "bnac-config", "name": "bnacConfig", "target": "bnacConfig" },
        { "pattern": "attribute-config",  "name": "attributeConfig",  "target": "attributeConfig" },
        { "pattern": "attribute-report",  "name": "attributeReport",  "target": "attributeReport" },
        { "pattern": "gis-config",        "name": "gisConfig",        "target": "gisConfig" },
        { "pattern": "demo-mode",        "name": "demoMode",        "target": "demoMode" },
        { "pattern": "api-docs",         "name": "apiDocs",         "target": "apiDocs" }
      ],
      "targets": {
        "changeDocuments": { "viewName": "ChangeDocuments",  "viewLevel": 1 },
        "dataQuality":      { "viewName": "DataQuality",      "viewLevel": 1 },
        "userAccess":      { "viewName": "UserAccess",       "viewLevel": 1 },
        "systemConfig":    { "viewName": "SystemConfig",     "viewLevel": 1 },
        "bnacConfig":      { "viewName": "BnacConfig",       "viewLevel": 1 },
        "attributeConfig": { "viewName": "AttributeConfig",  "viewLevel": 1 },
        "attributeReport": { "viewName": "AttributeReport",  "viewLevel": 1 },
        "gisConfig":       { "viewName": "GisConfig",        "viewLevel": 1 },
        "demoMode":        { "viewName": "DemoMode",         "viewLevel": 1 },
        "apiDocs":         { "viewName": "ApiDocs",          "viewLevel": 1 }
      }
    },
    "contentDensities": { "compact": true, "cozy": true }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  }
}
