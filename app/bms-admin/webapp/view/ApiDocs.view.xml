<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.ApiDocs"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  displayBlock="true">

  <Page id="apiDocsPage" showHeader="true">
    <customHeader>
      <Bar>
        <contentLeft><Title text="API Reference" level="H3" /></contentLeft>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiMediumMargin">

        <MessageStrip
          text="All endpoints require authentication (JWT / XSUAA). In development mode basic auth is applied. All write endpoints validate a CSRF token — fetch it first with GET /csrf-token."
          type="Information" showCloseButton="false" class="sapUiSmallMarginBottom" />

        <Panel expandable="true" expanded="true" headerText="Data Quality  /quality/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/qualityEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="Mass Upload  /mass-upload/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/uploadEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="Map  /map/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/mapEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="Mass Edit  /mass-edit/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/massEditEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="Audit / Change Log  /audit/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/auditEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="User Access  /access/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/accessEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="Bridge Attachments  /admin-bridges/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/attachmentEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="System Config  /system/api" class="sapUiSmallMarginBottom">
          <content><List class="sapUiSmallMargin" items="{/systemEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

        <Panel expandable="true" expanded="true" headerText="Custom Attributes  /attributes/api">
          <content><List class="sapUiSmallMargin" items="{/attributeEndpoints}">
            <StandardListItem title="{method} {path}" description="{desc}" info="{method}" infoState="{methodState}" />
          </List></content>
        </Panel>

      </VBox>
    </content>
  </Page>

</mvc:View>
