<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.AttributeConfig"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  displayBlock="true">

  <f:DynamicPage id="mainPage" headerExpanded="true" toggleHeaderOnTitleClick="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading><Title text="Attribute Configuration" level="H2"/></f:heading>
        <f:actions>
          <Button text="Export Template (Bridge)" icon="sap-icon://download" press=".onExportTemplate" data:objectType="bridge" class="sapUiSmallMarginEnd"/>
          <Button text="Export Template (Restriction)" icon="sap-icon://download" press=".onExportTemplate" data:objectType="restriction"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <layout:HorizontalLayout allowWrapping="false" class="sapUiSizeCompact" width="100%">

        <!-- LEFT: Object Type selector + Group list -->
        <Panel width="320px" headerText="Attribute Groups" class="sapUiSmallMarginEnd">
          <SegmentedButton id="objectTypeSelector" selectedKey="bridge" selectionChange=".onObjectTypeChange" width="100%" class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginTop">
            <items>
              <SegmentedButtonItem key="bridge" text="Bridge"/>
              <SegmentedButtonItem key="restriction" text="Restriction"/>
            </items>
          </SegmentedButton>
          <Toolbar>
            <ToolbarSpacer/>
            <Button icon="sap-icon://add" text="Add Group" press=".onAddGroup"/>
          </Toolbar>
          <List id="groupList" mode="SingleSelectMaster" selectionChange=".onGroupSelect" noDataText="No groups defined">
            <StandardListItem title="{name}" description="{internalKey}" info="{status}" infoState="{= ${status} === 'Active' ? 'Success' : 'None'}"/>
          </List>
        </Panel>

        <!-- MIDDLE: Attribute definitions in selected group -->
        <Panel id="defsPanel" width="380px" headerText="Attribute Definitions" visible="false" class="sapUiSmallMarginEnd">
          <Toolbar>
            <Button icon="sap-icon://edit" text="Edit Group" press=".onEditGroup"/>
            <Button icon="sap-icon://delete" text="" press=".onDeleteGroup" type="Reject"/>
            <ToolbarSpacer/>
            <Button icon="sap-icon://add" text="Add Attribute" press=".onAddAttribute"/>
          </Toolbar>
          <List id="attrList" mode="SingleSelectMaster" selectionChange=".onAttrSelect" noDataText="No attributes in this group">
            <StandardListItem title="{name}" description="{= ${dataType} + (${unit} ? ' (' + ${unit} + ')' : '')}" info="{status}" infoState="{= ${status} === 'Active' ? 'Success' : 'None'}"/>
          </List>
        </Panel>

        <!-- RIGHT: Attribute detail + allowed values + object type config -->
        <Panel id="attrDetailPanel" width="460px" headerText="Attribute Detail" visible="false">
          <Toolbar>
            <Button icon="sap-icon://edit" text="Edit" press=".onEditAttribute"/>
            <Button icon="sap-icon://delete" text="" press=".onDeleteAttribute" type="Reject"/>
            <ToolbarSpacer/>
          </Toolbar>
          <form:SimpleForm editable="false" layout="ResponsiveGridLayout" columnsL="2" columnsM="1" id="attrDetailForm">
            <form:content>
              <Label text="Name"/><Text id="detailName" text=""/>
              <Label text="Internal Key"/><Text id="detailKey" text=""/>
              <Label text="Data Type"/><Text id="detailType" text=""/>
              <Label text="Unit"/><Text id="detailUnit" text=""/>
              <Label text="Help Text"/><Text id="detailHelp" text=""/>
              <Label text="Min Value"/><Text id="detailMin" text=""/>
              <Label text="Max Value"/><Text id="detailMax" text=""/>
              <Label text="Status"/><Text id="detailStatus" text=""/>
            </form:content>
          </form:SimpleForm>

          <Title text="Object Type Configuration" level="H5" class="sapUiSmallMarginBegin sapUiTinyMarginTop"/>
          <Table id="configTable" noDataText="No object type configs">
            <columns>
              <Column><Text text="Object Type"/></Column>
              <Column><Text text="Enabled"/></Column>
              <Column><Text text="Required"/></Column>
              <Column><Text text="Order Override"/></Column>
              <Column><Text text=""/></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{objectType}"/>
                  <Switch state="{enabled}" change=".onConfigChange"/>
                  <Switch state="{required}" change=".onConfigChange"/>
                  <Input value="{displayOrder}" width="80px" change=".onConfigChange"/>
                  <Button icon="sap-icon://add" text="Add" visible="{= !${ID}}" press=".onAddConfig"/>
                </cells>
              </ColumnListItem>
            </items>
          </Table>

          <Title text="Allowed Values" level="H5" class="sapUiSmallMarginBegin sapUiTinyMarginTop"/>
          <Toolbar>
            <ToolbarSpacer/>
            <Button icon="sap-icon://add" text="Add Value" press=".onAddAllowedValue"/>
          </Toolbar>
          <Table id="allowedValuesTable" noDataText="Not applicable for this data type">
            <columns>
              <Column><Text text="Value"/></Column>
              <Column><Text text="Label"/></Column>
              <Column><Text text="Order"/></Column>
              <Column><Text text="Status"/></Column>
              <Column><Text text=""/></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{value}"/>
                  <Text text="{label}"/>
                  <Text text="{displayOrder}"/>
                  <Text text="{status}"/>
                  <Button icon="sap-icon://delete" type="Reject" press=".onDeleteAllowedValue"/>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

      </layout:HorizontalLayout>
    </f:content>
  </f:DynamicPage>
</mvc:View>
