<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.ChangeDocuments"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:t="sap.ui.table"
  displayBlock="true">

  <Page id="changeDocPage" showHeader="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="Change Document Report" level="H3" />
        </contentLeft>
        <contentRight>
          <Button icon="sap-icon://download" text="Export CSV" press=".onExportCsv" type="Transparent" />
          <Button icon="sap-icon://refresh"  text="Refresh"     press=".onRefresh"   type="Transparent" />
          <Button icon="sap-icon://sys-help" tooltip="How to use this page" press=".onShowHelp" type="Transparent" class="sapUiSmallMarginBegin" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiSmallMargin">

        <Panel headerText="Search &amp; Filter" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
          <content>
            <f:SimpleForm layout="ColumnLayout" columnsM="2" columnsL="3" columnsXL="4" editable="true">
              <f:content>
                <Label text="Object Type" />
                <Select id="filterObjectType" change=".onFilterChange" width="100%">
                  <items>
                    <core:Item key="" text="All Types" />
                    <core:Item key="Bridge" text="Bridge" />
                    <core:Item key="Restriction" text="Restriction" />
                    <core:Item key="GISConfig" text="GIS Config" />
                    <core:Item key="Lookup" text="Lookup / Code List" />
                  </items>
                </Select>

                <Label text="Change Source" />
                <Select id="filterSource" change=".onFilterChange" width="100%">
                  <items>
                    <core:Item key="" text="All Sources" />
                    <core:Item key="OData" text="OData (Fiori UI)" />
                    <core:Item key="MassEdit" text="Mass Edit" />
                    <core:Item key="MassUpload" text="Mass Upload" />
                  </items>
                </Select>

                <Label text="Changed By (User)" />
                <Input id="filterUser" placeholder="Enter user name or ID" liveChange=".onFilterChange" width="100%" />

                <Label text="Object Name / ID" />
                <Input id="filterObjectId" placeholder="Bridge name, restriction ref…" liveChange=".onFilterChange" width="100%" />

                <Label text="From Date" />
                <DatePicker id="filterDateFrom" change=".onFilterChange" valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy" width="100%" />

                <Label text="To Date" />
                <DatePicker id="filterDateTo" change=".onFilterChange" valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy" width="100%" />
              </f:content>
            </f:SimpleForm>
            <HBox justifyContent="End" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
              <Button text="Apply Filters" press=".onApplyFilters" type="Emphasized" />
              <Button text="Reset" press=".onResetFilters" type="Transparent" class="sapUiSmallMarginBegin" />
            </HBox>
          </content>
        </Panel>

        <HBox id="kpiBox" wrap="Wrap" class="sapUiSmallMarginBottom" visible="false">
          <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <GenericTile id="kpiTotal" header="Total Changes">
              <tileContent>
                <TileContent>
                  <content>
                    <NumericContent id="kpiTotalVal" value="0" scale="" withMargin="false" />
                  </content>
                </TileContent>
              </tileContent>
            </GenericTile>
            <Button icon="sap-icon://sys-help" tooltip="About: Total Changes" type="Transparent" press=".onTileInfo" class="sapUiTinyMarginTop">
              <customData><core:CustomData key="tileKey" value="totalChanges"/></customData>
            </Button>
          </VBox>
        </HBox>

        <Panel id="resultsPanel" expandable="false" visible="false">
          <headerToolbar>
            <Toolbar>
              <Title id="resultsTitle" text="Changes" level="H3" />
              <ToolbarSpacer />
              <Text id="recordCount" text="" />
            </Toolbar>
          </headerToolbar>
          <content>
            <List id="objectGroupList" mode="None" noDataText="No changes found for the selected filters."
                  growing="true" growingThreshold="50" growingScrollToLoad="true" />
          </content>
        </Panel>

        <Panel id="flatTablePanel" visible="false" headerText="All Field Changes" expandable="true" expanded="true">
          <headerToolbar>
            <Toolbar>
              <Title text="Field-Level Changes" level="H3" />
              <ToolbarSpacer />
              <Text id="flatCount" text="" />
            </Toolbar>
          </headerToolbar>
          <content>
            <t:Table id="changeTable" visibleRowCount="20" selectionMode="None"
                     enableBusyIndicator="true" noData="No changes match the current filters.">
              <t:columns>
                <t:Column width="160px"><Label text="Changed At" /><t:template><Text text="{changedAtDisplay}" wrapping="false" /></t:template></t:Column>
                <t:Column width="120px"><Label text="Changed By" /><t:template><Text text="{changedBy}" wrapping="false" /></t:template></t:Column>
                <t:Column width="100px"><Label text="Object Type" /><t:template><ObjectStatus text="{objectType}" state="{objectTypeState}" /></t:template></t:Column>
                <t:Column width="180px"><Label text="Object Name" /><t:template><Text text="{objectName}" wrapping="false" /></t:template></t:Column>
                <t:Column width="160px"><Label text="Field" /><t:template><Text text="{fieldName}" wrapping="false" /></t:template></t:Column>
                <t:Column width="200px"><Label text="Old Value" /><t:template><Text text="{oldValue}" wrapping="false" /></t:template></t:Column>
                <t:Column width="200px"><Label text="New Value" /><t:template><Text text="{newValue}" wrapping="false" /></t:template></t:Column>
                <t:Column width="100px"><Label text="Source" /><t:template><ObjectStatus text="{changeSource}" state="{sourceState}" /></t:template></t:Column>
              </t:columns>
            </t:Table>
          </content>
        </Panel>

        <VBox id="emptyState" alignItems="Center" justifyContent="Center" class="sapUiLargeMargin">
          <core:Icon src="sap-icon://history" size="5rem" color="Default" />
          <Title text="Apply filters to view change documents" level="H4" class="sapUiSmallMarginTop" />
          <Text text="Select object type, date range, or user and click Apply Filters." />
        </VBox>

      </VBox>
    </content>
  </Page>

</mvc:View>
