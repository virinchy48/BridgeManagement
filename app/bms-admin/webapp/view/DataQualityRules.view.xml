<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.DataQualityRules"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <!-- ── Page ──────────────────────────────────────────────────────── -->
  <Page id="dataQualityRulesPage" showHeader="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="Data Quality Rules" level="H3" />
        </contentLeft>
        <contentRight>
          <Button text="Add Rule" icon="sap-icon://add"     press=".onAddRule"    type="Emphasized" />
          <Button icon="sap-icon://refresh"                  press=".onRefresh"    type="Transparent" tooltip="Reload rules" class="sapUiSmallMarginBegin" />
          <Button icon="sap-icon://information"              press=".onShowRuleTypeRef" type="Transparent" tooltip="Rule type reference" class="sapUiSmallMarginBegin" />
          <Button icon="sap-icon://sys-help"                 press=".onShowHelp"   type="Transparent" tooltip="How to use this page" class="sapUiSmallMarginBegin" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiMediumMargin">

        <MessageStrip
          text="Rules are evaluated against every bridge when the Data Quality Dashboard loads. Disable a rule to stop it firing without deleting it. Changes take effect immediately."
          type="Information" showCloseButton="false" class="sapUiSmallMarginBottom" />

        <Panel expandable="false">
          <headerToolbar>
            <Toolbar>
              <Title text="Configured Rules" level="H4" />
              <ToolbarSpacer />
              <Text id="ruleCount" text="" />
            </Toolbar>
          </headerToolbar>
          <content>
            <Table id="rulesTable"
                   items="{path: '/rules'}"
                   mode="None"
                   noDataText="No rules configured. Click Add Rule to create one.">
              <columns>
                <Column width="5rem"   hAlign="Center"><Text text="On/Off" /></Column>
                <Column width="180px"><Text text="Rule Name" /></Column>
                <Column width="150px"><Text text="Category" /></Column>
                <Column width="80px"  hAlign="Center"><Text text="Severity" /></Column>
                <Column width="120px"><Text text="Rule Type" /></Column>
                <Column width="100px"><Text text="Field" /></Column>
                <Column><Text text="Message" /></Column>
                <Column width="6rem"  hAlign="Center"><Text text="Actions" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Switch state="{enabled}" change=".onToggleEnabled" />
                    <Text text="{name}" />
                    <Text text="{category}" wrapping="false" />
                    <ObjectStatus text="{severity}" state="{
                      path: 'severity',
                      formatter: '.formatSeverityState'
                    }" />
                    <Text text="{ruleType}" wrapping="false" />
                    <Text text="{field}" wrapping="false" />
                    <Text text="{message}" />
                    <HBox>
                      <Button icon="sap-icon://edit"   type="Transparent" tooltip="Edit rule"   press=".onEditRule" />
                      <Button icon="sap-icon://delete" type="Transparent" tooltip="Delete rule" press=".onDeleteRule" />
                    </HBox>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </content>
        </Panel>

      </VBox>
    </content>

  </Page>

  <!-- ── Edit / Add Rule Dialog ─────────────────────────────────────── -->
  <Dialog id="ruleDialog" title="Rule" contentWidth="480px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Rule Name" required="true" class="sapUiTinyMarginTop" />
        <Input id="dlgName" placeholder="e.g. Bridge Name Required" width="100%" />

        <Label text="Category" required="true" class="sapUiTinyMarginTop" />
        <Input id="dlgCategory" placeholder="e.g. Missing Mandatory Field" width="100%" />

        <Label text="Severity" required="true" class="sapUiTinyMarginTop" />
        <Select id="dlgSeverity" width="100%">
          <items>
            <core:Item key="critical" text="Critical" />
            <core:Item key="warning"  text="Warning" />
            <core:Item key="info"     text="Info" />
          </items>
        </Select>

        <Label text="Rule Type" required="true" class="sapUiTinyMarginTop" />
        <Select id="dlgRuleType" width="100%" change=".onRuleTypeChange">
          <items>
            <core:Item key="required_field"                text="required_field — field must not be empty" />
            <core:Item key="non_zero"                      text="non_zero — numeric field must not be zero" />
            <core:Item key="not_older_than_days"           text="not_older_than_days — date must be within N days" />
            <core:Item key="condition_requires_restriction" text="condition_requires_restriction — poor/critical needs restriction" />
            <core:Item key="freight_requires_nhvr"          text="freight_requires_nhvr — freight routes need NHVR assessment" />
          </items>
        </Select>

        <Label id="dlgFieldLabel" text="Bridge Field" class="sapUiTinyMarginTop" />
        <Input id="dlgField" placeholder="e.g. bridgeName, latitude, geoJson" width="100%" />

        <Label id="dlgConfigLabel" text="Config (JSON)" class="sapUiTinyMarginTop" />
        <Input id="dlgConfig" placeholder='e.g. {"days":730} or {"conditions":["Poor","Critical"]}' width="100%" />

        <Label text="Violation Message" required="true" class="sapUiTinyMarginTop" />
        <TextArea id="dlgMessage" rows="3" width="100%" placeholder="Message shown to the administrator in the dashboard" />

        <Label text="Sort Order" class="sapUiTinyMarginTop" />
        <StepInput id="dlgSortOrder" min="0" step="10" width="100%" />
      </VBox>
    </content>
    <beginButton>
      <Button text="Save" type="Emphasized" press=".onSaveRule" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCancelDialog" />
    </endButton>
  </Dialog>


</mvc:View>
