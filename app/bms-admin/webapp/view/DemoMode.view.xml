<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.DemoMode"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="demoModePage" showHeader="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="Demo Mode" level="H3" />
        </contentLeft>
        <contentRight>
          <Button icon="sap-icon://refresh" tooltip="Refresh status" press=".onRefresh" type="Transparent" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiMediumMargin">

        <!-- Status Banner -->
        <MessageStrip
          id="demoStatusStrip"
          text="{demo>/statusText}"
          type="{demo>/statusType}"
          showIcon="true"
          class="sapUiSmallMarginBottom" />

        <!-- What is Demo Mode -->
        <Panel headerText="About Demo Mode" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
          <VBox class="sapUiSmallMargin">
            <Text wrapping="true" class="sapUiSmallMarginBottom"
              text="Demo Mode loads a curated dataset of real NSW bridge assets sourced from Transport for NSW public records. Use this when demonstrating BMS capabilities to stakeholders — the data reflects actual bridge locations, condition ratings, restriction classifications, and structural attributes across the NSW road network." />
            <Text wrapping="true" class="sapUiSmallMarginBottom"
              text="Loading demo data replaces the current bridge dataset. Clearing demo data removes all bridges and returns the system to an empty state ready for a production data load." />
            <MessageStrip
              text="Demo Mode is for demonstration purposes only. Do not use in a live production environment with real operational data."
              type="Warning" showIcon="true" showCloseButton="false" />
          </VBox>
        </Panel>

        <!-- Demo Dataset Summary -->
        <Panel headerText="NSW Demo Dataset" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
          <VBox class="sapUiSmallMargin">
            <Text text="The demo dataset includes 30 real NSW bridges across all geographic regions:" wrapping="true" class="sapUiSmallMarginBottom" />
            <f:SimpleForm layout="ColumnLayout" columnsM="2" columnsL="3" editable="false">
              <f:content>
                <Label text="Sydney Metro" />       <Text text="7 bridges — Harbour Bridge, Anzac, Gladesville, Iron Cove, Mooney Mooney, Windsor, Ryde" />
                <Label text="Hunter" />             <Text text="3 bridges — Hexham, Maitland Rail, Karuah River" />
                <Label text="Northern NSW" />       <Text text="5 bridges — Grafton (Clarence), Manning River, Hastings River, Macleay River, Bellinger River" />
                <Label text="New England / Western NSW" />  <Text text="3 bridges — Macquarie River (Dubbo), Namoi River, Peel River (Tamworth)" />
                <Label text="Southern NSW / Illawarra" />   <Text text="4 bridges — Shoalhaven (Nowra), Clyde River, Moruya River, Bega River" />
                <Label text="Far West / Riverina" />        <Text text="4 bridges — Darling River (Bourke), Lachlan River, Murrumbidgee (Wagga), Murray River (Albury)" />
                <Label text="Central West / Other" />       <Text text="4 bridges — Fish River (Bathurst), Cox River, Murrumbidgee (Gundagai), Tumut River" />
              </f:content>
            </f:SimpleForm>
            <HBox class="sapUiSmallMarginTop" wrap="Wrap">
              <ObjectStatus text="Poor / Critical (rating 1–3)" state="Error"   class="sapUiTinyMarginEnd sapUiSmallMarginBottom" />
              <ObjectStatus text="Restricted loading"           state="Warning" class="sapUiTinyMarginEnd sapUiSmallMarginBottom" />
              <ObjectStatus text="Good / Excellent (rating 7–10)" state="Success" class="sapUiTinyMarginEnd sapUiSmallMarginBottom" />
              <ObjectStatus text="Heritage listed assets"       state="None"    class="sapUiTinyMarginEnd sapUiSmallMarginBottom" />
            </HBox>
          </VBox>
        </Panel>

        <!-- Controls -->
        <Panel headerText="Demo Controls" expandable="false" class="sapUiSmallMarginBottom">
          <VBox class="sapUiSmallMargin">
            <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
              <VBox class="sapUiMediumMarginEnd" width="18rem">
                <Title text="Load Demo Data" level="H5" />
                <Text wrapping="true" class="sapUiTinyMarginTop sapUiSmallMarginBottom"
                  text="Clears current bridge data and loads 30 real NSW bridges from the Transport for NSW public asset dataset." />
                <Button
                  id="btnLoadDemo"
                  text="Load NSW Demo Data"
                  icon="sap-icon://begin"
                  type="Emphasized"
                  press=".onLoadDemoData"
                  enabled="{= !${demo>/demoActive} }" />
              </VBox>
              <VBox width="18rem">
                <Title text="Clear Demo Data" level="H5" />
                <Text wrapping="true" class="sapUiTinyMarginTop sapUiSmallMarginBottom"
                  text="Removes all demo bridge records and resets the system to an empty state for production data import." />
                <Button
                  id="btnClearDemo"
                  text="Clear Demo Data"
                  icon="sap-icon://clear-all"
                  type="Reject"
                  press=".onClearDemoData"
                  enabled="{demo>/demoActive}" />
              </VBox>
            </HBox>
            <Text text="Note: Both operations are immediate and cannot be undone. Ensure you have a backup of any production data before using these controls." class="sapUiTinyText sapThemePositive" />
          </VBox>
        </Panel>

        <!-- Current bridge count -->
        <Panel headerText="Current System State" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
          <f:SimpleForm layout="ColumnLayout" columnsM="1" columnsL="2" editable="false">
            <f:content>
              <Label text="Total Bridges in System" />
              <ObjectStatus text="{demo>/bridgeCount}" state="{= ${demo>/bridgeCount} > 0 ? 'Success' : 'None' }" />
              <Label text="Demo Mode Status" />
              <ObjectStatus text="{demo>/statusLabel}" state="{demo>/statusState}" />
              <Label text="Data Source" />
              <Text text="{demo>/dataSource}" />
            </f:content>
          </f:SimpleForm>
        </Panel>

      </VBox>
    </content>

  </Page>

</mvc:View>
