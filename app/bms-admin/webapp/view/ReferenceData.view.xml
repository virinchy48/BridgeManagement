<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.ReferenceData"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:layout="sap.ui.layout"
  displayBlock="true">

  <Page id="refDataPage" showHeader="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="Reference Data Administration" level="H3" />
        </contentLeft>
        <contentRight>
          <Button text="Add Entry" type="Emphasized" icon="sap-icon://add"     press=".onAddEntry" />
          <Button text="Refresh"   type="Transparent" icon="sap-icon://refresh" press=".onRefresh"  class="sapUiSmallMarginBegin" />
          <Button icon="sap-icon://sys-help" tooltip="How to use this page" press=".onShowHelp" type="Transparent" class="sapUiSmallMarginBegin" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

        <HBox alignItems="Center" class="sapUiSmallMarginBottom" wrap="Wrap">
          <Select id="entitySelect" change=".onEntityChange" class="sapUiSmallMarginEnd" width="16rem" />
          <Input  id="searchInput"  placeholder="Search code or name..." liveChange=".onSearch" width="20rem" showClearIcon="true" />
        </HBox>

        <Table id="codeListTable" mode="SingleSelectMaster" selectionChange=".onRowSelect"
               items="{/items}" noDataText="No entries found. Select a code list above."
               growing="true" growingThreshold="50" class="sapUiSmallMarginBottom">
          <headerToolbar>
            <OverflowToolbar>
              <Title id="tableTitle" text="Entries" level="H3" />
              <ToolbarSpacer />
              <Text id="tableCount" text="" class="sapUiSmallMarginEnd" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column width="10rem"><Text text="Code" /></Column>
            <Column width="18rem"><Text text="Name" /></Column>
            <Column><Text text="Description" /></Column>
            <Column width="10rem" hAlign="End"><Text text="Actions" /></Column>
          </columns>
          <items>
            <ColumnListItem>
              <cells>
                <Text text="{code}" wrapping="false" />
                <Text text="{name}" wrapping="false" />
                <Text text="{descr}" />
                <HBox justifyContent="End">
                  <Button text="Edit"   type="Transparent" icon="sap-icon://edit"   press=".onEdit"   class="sapUiTinyMarginEnd" />
                  <Button text="Delete" type="Negative"    icon="sap-icon://delete" press=".onDelete" />
                </HBox>
              </cells>
            </ColumnListItem>
          </items>
        </Table>

      </VBox>
    </content>
  </Page>

  <!-- Edit / Add Dialog (view-level dependent) -->
  <Dialog id="editDialog" title="Entry" contentWidth="28rem">
    <content>
      <layout:SimpleForm editable="true" layout="ResponsiveGridLayout"
        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
        columnsXL="1" columnsL="1" columnsM="1" class="sapUiSmallMargin">
        <Label text="Code" required="true" />
        <Input id="dlgCode" placeholder="Enter code..." maxLength="80" />
        <Label text="Name" />
        <Input id="dlgName" placeholder="Enter name..." maxLength="255" />
        <Label text="Description" />
        <Input id="dlgDescr" placeholder="Enter description..." maxLength="1000" />
      </layout:SimpleForm>
    </content>
    <beginButton><Button text="Save"   type="Emphasized" press=".onSave"          /></beginButton>
    <endButton>  <Button text="Cancel"                   press=".onCancelDialog"  /></endButton>
  </Dialog>

</mvc:View>
