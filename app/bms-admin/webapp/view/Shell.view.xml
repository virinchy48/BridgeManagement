<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.Shell"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:tnt="sap.tnt"
  displayBlock="true">

  <tnt:ToolPage id="toolPage" sideExpanded="false">

    <tnt:header>
      <tnt:ToolHeader>
        <Button icon="sap-icon://menu2" type="Transparent" press=".onToggleSideNav" tooltip="Toggle navigation" />
        <Title text="BMS Administration" titleStyle="H4" class="sapUiSmallMarginBegin" />
        <Text id="appVersionEnv" text="" class="sapUiSmallMarginBegin sapMuted" />
        <ToolbarSpacer />
        <!-- Critical quality alert badge: shown when critical DQ issues exist -->
        <Button id="qualityAlertBtn" icon="sap-icon://alert" type="Reject"
                tooltip="Critical data quality issues detected: click to view"
                press=".onQualityAlertPress" visible="false" class="sapUiSmallMarginEnd" />
      </tnt:ToolHeader>
    </tnt:header>

    <tnt:sideContent>
      <tnt:SideNavigation id="sideNav" itemSelect=".onNavSelect">
        <tnt:item>
          <tnt:NavigationList id="navList">
            <tnt:NavigationListItem text="Change Documents"  key="changeDocuments" icon="sap-icon://history"       />
            <tnt:NavigationListItem text="Data Quality"      key="dataQuality"     icon="sap-icon://quality-issue" />
            <tnt:NavigationListItem text="User Access"       key="userAccess"      icon="sap-icon://employee"      />
            <tnt:NavigationListItem text="System Config"     key="systemConfig"    icon="sap-icon://settings"      />
            <tnt:NavigationListItem text="BNAC Config"       key="bnacConfig"      icon="sap-icon://chain-link"    />
            <tnt:NavigationListItem text="GIS Config"        key="gisConfig"       icon="sap-icon://map"           />
            <tnt:NavigationListItem text="Attribute Config"  key="attributeConfig" icon="sap-icon://customize"     />
            <tnt:NavigationListItem text="Attribute Report"  key="attributeReport" icon="sap-icon://table-chart"   />
            <tnt:NavigationListItem text="API Reference"     key="apiDocs"         icon="sap-icon://developer-settings" />
            <tnt:NavigationListItem text="Demo Mode"         key="demoMode"        icon="sap-icon://simulate"      />
          </tnt:NavigationList>
        </tnt:item>
      </tnt:SideNavigation>
    </tnt:sideContent>

    <tnt:mainContents>
      <NavContainer id="adminNavContainer" height="100%" />
    </tnt:mainContents>

  </tnt:ToolPage>

</mvc:View>
