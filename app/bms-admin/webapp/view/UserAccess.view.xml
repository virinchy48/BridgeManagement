<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.UserAccess"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="userAccessPage" showHeader="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="User Access &amp; Activity" level="H3" />
        </contentLeft>
        <contentRight>
          <Button text="Refresh" icon="sap-icon://refresh" press=".onRefresh" type="Emphasized" />
          <Button icon="sap-icon://sys-help" tooltip="How to use this page" press=".onShowHelp" type="Transparent" class="sapUiSmallMarginBegin" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiMediumMargin">

        <MessageStrip
          text="Role assignment is managed in SAP BTP Cockpit. This view shows who has recently accessed BMS and their activity."
          type="Information" showCloseButton="false" class="sapUiSmallMarginBottom" />

        <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
          <VBox class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
            <GenericTile id="tileTotalUsers" header="Total Users" subheader="All time" press=".onTilePress">
              <tileContent><TileContent><content><NumericContent id="numTotalUsers" value="0" valueColor="Neutral" icon="sap-icon://employee" /></content></TileContent></tileContent>
            </GenericTile>
            <Button icon="sap-icon://sys-help" tooltip="About: Total Users" type="Transparent" press=".onTileInfo" class="sapUiTinyMarginTop">
              <customData><core:CustomData key="tileKey" value="totalUsers"/></customData>
            </Button>
          </VBox>
          <VBox class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
            <GenericTile id="tileActiveToday" header="Active Today" subheader="Last 24 hours" press=".onTilePress">
              <tileContent><TileContent><content><NumericContent id="numActiveToday" value="0" valueColor="Good" icon="sap-icon://activity-2" /></content></TileContent></tileContent>
            </GenericTile>
            <Button icon="sap-icon://sys-help" tooltip="About: Active Today" type="Transparent" press=".onTileInfo" class="sapUiTinyMarginTop">
              <customData><core:CustomData key="tileKey" value="activeToday"/></customData>
            </Button>
          </VBox>
          <VBox class="sapUiTinyMarginBottom">
            <GenericTile id="tileActiveWeek" header="Active This Week" subheader="Last 7 days" press=".onTilePress">
              <tileContent><TileContent><content><NumericContent id="numActiveWeek" value="0" valueColor="Critical" icon="sap-icon://calendar" /></content></TileContent></tileContent>
            </GenericTile>
            <Button icon="sap-icon://sys-help" tooltip="About: Active This Week" type="Transparent" press=".onTileInfo" class="sapUiTinyMarginTop">
              <customData><core:CustomData key="tileKey" value="activeWeek"/></customData>
            </Button>
          </VBox>
        </HBox>

        <Panel headerText="Recent User Activity" expandable="false">
          <headerToolbar>
            <Toolbar>
              <Input id="searchUser" placeholder="Search user..." liveChange=".onSearch" width="20rem" />
              <ToolbarSpacer />
              <Text id="userCount" text="" />
            </Toolbar>
          </headerToolbar>
          <Table id="userTable" mode="None" noDataText="No user activity recorded yet." items="{path: '/filtered'}">
            <columns>
              <Column width="15rem"><Text text="User ID" /></Column>
              <Column width="14rem"><Text text="Last Seen" /></Column>
              <Column><Text text="Last Action Path" /></Column>
              <Column width="10rem" hAlign="End"><Text text="Total Actions" /></Column>
              <Column width="11rem"><Text text="Status" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{userId}" />
                  <Text text="{lastSeenDisplay}" />
                  <Text text="{lastPath}" wrapping="false" />
                  <ObjectNumber number="{actionCount}" unit="actions" />
                  <ObjectStatus text="{activityStatus}" state="{activityState}" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

      </VBox>
    </content>
  </Page>

</mvc:View>
