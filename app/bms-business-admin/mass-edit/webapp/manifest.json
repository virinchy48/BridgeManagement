{
  "_version": "1.8.0",
  "sap.app": {
    "id": "bms.massedit",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "BridgeManagementService": {
        "uri": "/bridge-management/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "MassEdit-manage": {
          "semanticObject": "MassEdit",
          "action": "manage",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "title": "{{appTitle}}",
          "icon": "sap-icon://edit"
        }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.fe.templates": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      },
      "": {
        "dataSource": "BridgeManagementService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        },
        "type": "sap.ui.model.odata.v4.ODataModel"
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "BridgeGridList",
          "target": "BridgeGridList"
        },
        {
          "pattern": "BridgeGrid({key}):?query:",
          "name": "BridgeGridDetails",
          "target": "BridgeGridDetails"
        }
      ],
      "targets": {
        "BridgeGridList": {
          "type": "Component",
          "id": "BridgeGridList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "BridgeGrid",
              "liveMode": true,
              "navigation": {
                "BridgeGrid": {
                  "detail": {
                    "route": "BridgeGridDetails"
                  }
                }
              }
            }
          }
        },
        "BridgeGridDetails": {
          "type": "Component",
          "id": "BridgeGridDetails",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "BridgeGrid"
            }
          }
        }
      },
      "config": {
        "routerClass": "sap.fe.core.AppRouter"
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}