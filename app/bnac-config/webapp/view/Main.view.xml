<mvc:View controllerName="BridgeManagement.bnacconfig.controller.Main"
  xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form" displayBlock="true">
  <App id="bnacApp">
    <Page id="bnacPage" showHeader="false" class="sapUiContentPadding">
      <content>
        <VBox class="sapUiSmallMargin">

          <!-- Section: BNAC Environment URLs -->
          <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
            <Title text="BNAC Environment URLs" level="H3" />
            <HBox>
              <Button icon="sap-icon://refresh" text="Refresh" press=".onRefreshEnvs" type="Transparent" />
              <Button icon="sap-icon://add" text="Add Environment" press=".onAddEnv" type="Emphasized" class="sapUiSmallMarginBegin" />
            </HBox>
          </HBox>

          <Table id="envTable" mode="None" noDataText="No environments configured."
                 items="{envModel>/environments}" class="sapUiSmallMarginBottom">
            <columns>
              <Column width="120px"><Text text="Environment" /></Column>
              <Column width="320px"><Text text="Base URL" /></Column>
              <Column><Text text="Description" /></Column>
              <Column width="80px" hAlign="Center"><Text text="Active" /></Column>
              <Column width="140px"><Text text="Modified By" /></Column>
              <Column width="100px" hAlign="Center"><Text text="Actions" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{envModel>environment}" />
                  <Link text="{envModel>baseUrl}" href="{envModel>baseUrl}" target="_blank" />
                  <Text text="{envModel>description}" />
                  <CheckBox selected="{envModel>active}" editable="false" />
                  <Text text="{envModel>modifiedBy}" />
                  <HBox justifyContent="Center">
                    <Button icon="sap-icon://edit" type="Transparent" press=".onEditEnv" tooltip="Edit" />
                    <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteEnv" tooltip="Delete" />
                  </HBox>
                </cells>
              </ColumnListItem>
            </items>
          </Table>

          <!-- Section: BNAC Object ID Mass Load -->
          <Title text="BNAC Object ID Mass Load" level="H3" class="sapUiMediumMarginTop sapUiSmallMarginBottom" />
          <HBox alignItems="Center" class="sapUiSmallMarginBottom">
            <Input id="fileNameDisplay" placeholder="CSV format: bridgeId,bnacObjectId" width="280px" editable="false" />
            <Button text="Browse..." press=".onBrowse" class="sapUiSmallMarginBegin" />
            <Select id="envSelect" width="120px" class="sapUiSmallMarginBegin">
              <items>
                <core:Item key="DEV" text="DEV" xmlns:core="sap.ui.core" />
                <core:Item key="PREPROD" text="PREPROD" xmlns:core="sap.ui.core" />
                <core:Item key="PROD" text="PROD" xmlns:core="sap.ui.core" />
                <core:Item key="TEST" text="TEST" xmlns:core="sap.ui.core" />
              </items>
            </Select>
            <Button id="uploadBtn" icon="sap-icon://upload" text="Upload BNAC IDs" press=".onUpload"
                    type="Emphasized" class="sapUiSmallMarginBegin" enabled="false" />
          </HBox>
          <MessageStrip id="uploadResult" visible="false" showCloseButton="true" class="sapUiSmallMarginBottom" />

          <!-- Section: Load History -->
          <Title text="Load History" level="H3" class="sapUiMediumMarginTop sapUiSmallMarginBottom" />
          <Table id="histTable" mode="None" noDataText="No BNAC load history."
                 items="{histModel>/history}">
            <columns>
              <Column width="180px"><Text text="Loaded At" /></Column>
              <Column width="160px"><Text text="Loaded By" /></Column>
              <Column><Text text="File Name" /></Column>
              <Column width="80px" hAlign="Center"><Text text="Env" /></Column>
              <Column width="80px" hAlign="End"><Text text="Total" /></Column>
              <Column width="80px" hAlign="End"><Text text="Success" /></Column>
              <Column width="80px" hAlign="End"><Text text="Failed" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{histModel>loadedAtDisplay}" />
                  <Text text="{histModel>loadedBy}" />
                  <Text text="{histModel>fileName}" />
                  <ObjectStatus text="{histModel>environment}" state="Information" />
                  <ObjectNumber number="{histModel>total}" unit="" emphasized="false" />
                  <ObjectNumber number="{histModel>success}" unit="" state="Success" />
                  <ObjectNumber number="{histModel>failed}" unit="" state="{histModel>failedState}" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>

        </VBox>
      </content>
    </Page>
  </App>
</mvc:View>
