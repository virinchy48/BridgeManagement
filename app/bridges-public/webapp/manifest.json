{
  "_version": "1.65.0",
  "sap.app": {
    "id": "BridgeManagement.bridgespublic",
    "type": "application",
    "title": "Bridge Information — Public View",
    "description": "Curated read-only bridge card for external stakeholders (councils, carriers, public)",
    "applicationVersion": { "version": "1.0.0" },
    "ach": "NHVR-BIS",
    "dataSources": {
      "publicBridgeService": {
        "uri": "/public-bridge/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://building",
      "favIcon": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    },
    "supportedThemes": ["sap_horizon", "sap_fiori_3"]
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "BridgeManagement.bridgespublic.view.BridgePublicCard",
      "type": "XML",
      "async": true,
      "id": "BridgePublicCardView"
    },
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.f": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "publicBridge": {
        "dataSource": "publicBridgeService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "BridgeManagement.bridgespublic.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "type": "JSON",
        "viewType": "XML",
        "viewPath": "BridgeManagement.bridgespublic.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "async": true
      },
      "routes": [
        {
          "name": "BridgePublicCard",
          "pattern": ":?query:",
          "target": "BridgePublicCard"
        }
      ],
      "targets": {
        "BridgePublicCard": {
          "viewType": "XML",
          "id": "BridgePublicCard",
          "viewName": "BridgePublicCard"
        }
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "standalone"
  }
}
