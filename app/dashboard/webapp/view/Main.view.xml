<mvc:View
  controllerName="BridgeManagement.dashboard.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  xmlns:f="sap.f"
  displayBlock="true">

  <App id="dashboardApp">
    <Page
      id="dashboardPage"
      showHeader="false"
      busy="{view>/busy}"
      class="dashboardPage sapUiResponsivePadding--content">

      <content>
        <ScrollContainer height="100%" width="100%" vertical="true" horizontal="false">
          <VBox class="dashboardShell">

            <!-- Page heading row matching DynamicPage title style -->
            <HBox justifyContent="SpaceBetween" alignItems="Center" class="dashboardTitleRow sapUiSmallMarginBottom">
              <VBox>
                <Title text="{i18n>appTitle}" level="H1" />
                <Text text="{i18n>pageSubtitle}" class="dashboardSubtitle" />
              </VBox>
              <HBox alignItems="Center" gap="0.5rem">
                <Select id="stateFilter" change="onStateFilterChange" width="150px" class="sapUiTinyMarginEnd">
                  <items>
                    <core:Item key="" text="All States"/>
                    <core:Item key="NSW" text="NSW"/>
                    <core:Item key="VIC" text="VIC"/>
                    <core:Item key="QLD" text="QLD"/>
                    <core:Item key="WA" text="WA"/>
                    <core:Item key="SA" text="SA"/>
                    <core:Item key="TAS" text="TAS"/>
                    <core:Item key="ACT" text="ACT"/>
                    <core:Item key="NT" text="NT"/>
                  </items>
                </Select>
                <VBox alignItems="Center">
                  <Button
                    icon="sap-icon://refresh"
                    tooltip="{i18n>refreshTooltip}"
                    press=".onRefresh"
                    type="Transparent"
                    class="dashboardRefreshBtn" />
                  <Text text="{view>/lastRefreshedLabel}" class="dashboardMuted dashboardRefreshTimestamp" />
                </VBox>
                <Button
                  icon="sap-icon://information"
                  tooltip="How to use this dashboard"
                  press=".onShowHelp"
                  type="Transparent" />
              </HBox>
            </HBox>

            <!-- ═══ ROW 1 · Network Summary KPIs ═══ -->
            <Title text="{i18n>sectionSummary}" level="H4" class="dashboardSectionTitle" />
            <FlexBox wrap="Wrap" class="sapUiSmallMarginBottom">

              <VBox class="dashboardKpiTileWrapper sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <GenericTile
                  header="{i18n>kpiTotalAssets}"
                  subheader="{i18n>kpiTotalAssetsSubtitle}"
                  frameType="OneByOne"
                  press=".onNavigateBridges"
                  class="dashboardKpiTile">
                  <tileContent>
                    <TileContent>
                      <content>
                        <NumericContent
                          value="{view>/totalBridges}"
                          icon="sap-icon://functional-location"
                          valueColor="Neutral"
                          withMargin="false" />
                      </content>
                    </TileContent>
                  </tileContent>
                </GenericTile>
                <Button icon="sap-icon://information" tooltip="About: Total Assets" type="Transparent"
                  press=".onTileInfo" class="dashboardKpiTileInfo">
                  <customData><core:CustomData key="tileKey" value="totalAssets"/></customData>
                </Button>
              </VBox>

              <VBox class="dashboardKpiTileWrapper sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <GenericTile
                  header="{i18n>kpiActiveRestrictions}"
                  subheader="{i18n>kpiActiveRestrictionsSubtitle}"
                  frameType="OneByOne"
                  press=".onNavigateRestrictions"
                  class="dashboardKpiTile">
                  <tileContent>
                    <TileContent>
                      <content>
                        <NumericContent
                          value="{view>/activeRestrictions}"
                          icon="sap-icon://alert"
                          valueColor="{= ${view>/activeRestrictions} > 0 ? 'Critical' : 'Neutral' }"
                          withMargin="false" />
                      </content>
                    </TileContent>
                  </tileContent>
                </GenericTile>
                <Button icon="sap-icon://information" tooltip="About: Active Restrictions" type="Transparent"
                  press=".onTileInfo" class="dashboardKpiTileInfo">
                  <customData><core:CustomData key="tileKey" value="activeRestrictions"/></customData>
                </Button>
              </VBox>

              <VBox class="dashboardKpiTileWrapper sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <GenericTile
                  header="{i18n>kpiBridgesClosed}"
                  subheader="{i18n>kpiBridgesClosedSubtitle}"
                  frameType="OneByOne"
                  press=".onNavigateClosedBridges"
                  class="dashboardKpiTile">
                  <tileContent>
                    <TileContent>
                      <content>
                        <NumericContent
                          value="{view>/closedBridges}"
                          icon="sap-icon://locked"
                          valueColor="{= ${view>/closedBridges} > 0 ? 'Critical' : 'Good' }"
                          withMargin="false" />
                      </content>
                    </TileContent>
                  </tileContent>
                </GenericTile>
                <Button icon="sap-icon://information" tooltip="About: Bridges Closed" type="Transparent"
                  press=".onTileInfo" class="dashboardKpiTileInfo">
                  <customData><core:CustomData key="tileKey" value="bridgesClosed"/></customData>
                </Button>
              </VBox>

              <VBox class="dashboardKpiTileWrapper sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <GenericTile
                  header="Overdue Inspections"
                  subheader="Inspections past due date"
                  frameType="OneByOne"
                  press=".onNavigateOverdue"
                  class="dashboardKpiTile">
                  <tileContent>
                    <TileContent>
                      <content>
                        <NumericContent
                          value="{view>/overdueCount}"
                          icon="sap-icon://calendar"
                          valueColor="{= ${view>/overdueCount} > 0 ? 'Critical' : 'Good' }"
                          withMargin="false" />
                      </content>
                    </TileContent>
                  </tileContent>
                </GenericTile>
              </VBox>

              <VBox class="dashboardKpiTileWrapper sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <GenericTile
                  header="Gazette Issues"
                  subheader="Expired or expiring soon"
                  frameType="OneByOne"
                  press=".onNavigateGazette"
                  class="dashboardKpiTile">
                  <tileContent>
                    <TileContent>
                      <content>
                        <NumericContent
                          value="{view>/gazetteIssueCount}"
                          icon="sap-icon://official-service"
                          valueColor="{= ${view>/gazetteIssueCount} > 0 ? 'Critical' : 'Good' }"
                          withMargin="false" />
                      </content>
                    </TileContent>
                  </tileContent>
                </GenericTile>
              </VBox>

            </FlexBox>

            <!-- ═══ ROW 2 · Condition State Distribution ═══ -->
            <Title text="{i18n>sectionCondition}" level="H4" class="dashboardSectionTitle" />
            <VBox class="dashboardCard sapUiSmallMarginBottom">

              <!-- Card header row -->
              <HBox justifyContent="SpaceBetween" alignItems="Center" class="dashboardCardHeader">
                <HBox alignItems="Center">
                  <core:Icon src="sap-icon://status-positive" class="dashboardConditionHeaderIcon sapUiTinyMarginEnd" />
                  <Text text="{view>/conditionSummaryLabel}" class="dashboardConditionSummary" />
                </HBox>
                <Text text="{view>/totalBridges} {i18n>bridgesLabel}" class="dashboardMuted" />
              </HBox>

              <!-- Condition rows -->
              <VBox class="dashboardConditionRows">
                <List
                  items="{view>/conditionRows}"
                  showSeparators="None"
                  class="dashboardConditionList">
                  <items>
                    <CustomListItem type="Active" press=".onConditionRowPress" class="dashboardConditionItem">
                      <HBox alignItems="Center" class="dashboardConditionRow">
                        <core:Icon src="{view>icon}" color="{view>color}" size="1rem" class="dashboardConditionIcon" />
                        <Text text="{view>label}" width="5.5rem" class="dashboardConditionLabel" />
                        <ProgressIndicator
                          percentValue="{view>pct}"
                          displayValue="{view>pctText}"
                          state="{view>state}"
                          showValue="true"
                          width="100%"
                          class="dashboardConditionBar">
                          <layoutData>
                            <FlexItemData growFactor="1" shrinkFactor="1" minWidth="0px" />
                          </layoutData>
                        </ProgressIndicator>
                        <Text text="{view>pct}% · {view>count}" class="dashboardConditionCount" />
                      </HBox>
                    </CustomListItem>
                  </items>
                </List>
              </VBox>

            </VBox>

            <!-- ═══ ROW 3 · Key Indicators ═══ -->
            <Title text="{i18n>sectionKeyIndicators}" level="H4" class="dashboardSectionTitle" />
            <FlexBox wrap="Wrap" class="sapUiSmallMarginBottom">

              <VBox class="dashboardIndicatorCard sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <HBox justifyContent="SpaceBetween" alignItems="Center">
                  <Text text="{i18n>indicatorSufficiency}" class="dashboardIndicatorLabel" />
                  <Button icon="sap-icon://information" tooltip="About: Sufficiency Rating" type="Transparent" press=".onTileInfo">
                    <customData><core:CustomData key="tileKey" value="sufficiency"/></customData>
                  </Button>
                </HBox>
                <HBox alignItems="Baseline">
                  <Text text="{view>/sufficiencyPct}" class="dashboardIndicatorValue" />
                  <Text text="%" class="dashboardIndicatorUnit" />
                </HBox>
                <Text text="{i18n>indicatorSufficiencyHint}" class="dashboardMuted" />
                <Link text="View Network Health →" press=".onNavigateSufficiency" class="dashboardIndicatorLink" />
              </VBox>

              <VBox class="dashboardIndicatorCard sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <HBox justifyContent="SpaceBetween" alignItems="Center">
                  <Text text="{i18n>indicatorScourCritical}" class="dashboardIndicatorLabel" />
                  <Button icon="sap-icon://information" tooltip="About: Scour Critical Bridges" type="Transparent" press=".onTileInfo">
                    <customData><core:CustomData key="tileKey" value="scourCritical"/></customData>
                  </Button>
                </HBox>
                <HBox alignItems="Baseline">
                  <Text text="{view>/scourCritical}" class="{= ${view>/scourCritical} > 0 ? 'dashboardIndicatorValueCritical' : 'dashboardIndicatorValue' }" />
                </HBox>
                <Text text="{i18n>indicatorScourCriticalHint}" class="dashboardMuted" />
                <Link text="View Risk Register →" press=".onNavigateScourCritical" class="dashboardIndicatorLink" />
              </VBox>

              <VBox class="dashboardIndicatorCard sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <HBox justifyContent="SpaceBetween" alignItems="Center">
                  <Text text="{i18n>indicatorDeficient}" class="dashboardIndicatorLabel" />
                  <Button icon="sap-icon://information" tooltip="About: Structurally Deficient" type="Transparent" press=".onTileInfo">
                    <customData><core:CustomData key="tileKey" value="deficient"/></customData>
                  </Button>
                </HBox>
                <HBox alignItems="Baseline">
                  <Text text="{view>/deficient}" class="{= ${view>/deficient} > 0 ? 'dashboardIndicatorValueCritical' : 'dashboardIndicatorValue' }" />
                </HBox>
                <Text text="{i18n>indicatorDeficientHint}" class="dashboardMuted" />
                <Link text="View Risk Register →" press=".onNavigateDeficient" class="dashboardIndicatorLink" />
              </VBox>

              <VBox class="dashboardIndicatorCard sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <Text text="Network Condition Index" class="dashboardIndicatorLabel" />
                <HBox alignItems="Baseline">
                  <Text text="{view>/nci}"
                    class="{= ${view>/nci} >= 80 ? 'dashboardIndicatorValue' : ${view>/nci} >= 60 ? 'dashboardIndicatorValueWarn' : 'dashboardIndicatorValueCritical' }" />
                  <Text text="%" class="dashboardIndicatorUnit" />
                </HBox>
                <Text text="Weighted condition score (0–100)" class="dashboardMuted" />
                <Link text="View Network Health →" press=".onNavigateSufficiency" class="dashboardIndicatorLink" />
              </VBox>

              <VBox class="dashboardIndicatorCard sapUiTinyMarginEnd sapUiTinyMarginBottom">
                <Text text="Deficiency Rate" class="dashboardIndicatorLabel" />
                <HBox alignItems="Baseline">
                  <Text text="{view>/deficiencyRate}"
                    class="{= ${view>/deficiencyRate} > 15 ? 'dashboardIndicatorValueCritical' : ${view>/deficiencyRate} > 5 ? 'dashboardIndicatorValueWarn' : 'dashboardIndicatorValue' }" />
                  <Text text="%" class="dashboardIndicatorUnit" />
                </HBox>
                <Text text="Bridges rated Poor or Critical" class="dashboardMuted" />
                <Link text="View Risk Register →" press=".onNavigateDeficient" class="dashboardIndicatorLink" />
              </VBox>

            </FlexBox>

            <!-- ═══ ROW 4 · Priority Actions ═══ -->
            <Title text="Priority Actions" level="H4" class="dashboardSectionTitle" />
            <FlexBox wrap="Wrap" alignItems="Start" class="sapUiSmallMarginBottom">

              <VBox class="dashboardCard dashboardPriorityPanel sapUiTinyMarginEnd sapUiSmallMarginBottom">
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="dashboardCardHeader">
                  <HBox alignItems="Center">
                    <core:Icon src="sap-icon://calendar" class="sapUiTinyMarginEnd" color="#BB0000" />
                    <Text text="Overdue Inspections" class="dashboardConditionSummary" />
                  </HBox>
                  <ObjectStatus
                    text="{view>/overdueCount} overdue"
                    state="{= ${view>/overdueCount} > 0 ? 'Error' : 'Success' }"/>
                </HBox>
                <Table id="overdueTable"
                  items="{view>/overdueInspections}"
                  noDataText="No overdue inspections"
                  showSeparators="Inner"
                  class="sapUiNoContentPadding">
                  <columns>
                    <Column hAlign="Begin"><Text text="Bridge"/></Column>
                    <Column width="4.5rem"><Text text="State"/></Column>
                    <Column width="7rem" hAlign="End"><Text text="Days Overdue"/></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Active" press="onBridgePress">
                      <cells>
                        <Text text="{view>bridgeName}" wrapping="false" maxLines="1"/>
                        <Text text="{view>state}"/>
                        <ObjectStatus text="{view>daysOverdue} days" state="Error"/>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
                <Link text="View all overdue inspections →" press=".onNavigateOverdue" class="dashboardIndicatorLink sapUiTinyMarginTop" />
              </VBox>

              <VBox class="dashboardCard dashboardPriorityPanel sapUiSmallMarginBottom">
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="dashboardCardHeader">
                  <HBox alignItems="Center">
                    <core:Icon src="sap-icon://official-service" class="sapUiTinyMarginEnd" color="#E76500" />
                    <Text text="Gazette Expiry Watchlist" class="dashboardConditionSummary" />
                  </HBox>
                  <ObjectStatus
                    text="{view>/gazetteIssueCount} issues"
                    state="{= ${view>/gazetteIssueCount} > 0 ? 'Error' : 'Success' }"/>
                </HBox>
                <Table id="gazetteTable"
                  items="{view>/gazetteWatchlist}"
                  noDataText="No urgent gazette expiries"
                  showSeparators="Inner"
                  class="sapUiNoContentPadding">
                  <columns>
                    <Column hAlign="Begin"><Text text="Bridge"/></Column>
                    <Column width="4.5rem"><Text text="State"/></Column>
                    <Column width="6rem"><Text text="Urgency"/></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Active" press="onBridgePress">
                      <cells>
                        <Text text="{view>bridgeName}" wrapping="false" maxLines="1"/>
                        <Text text="{view>state}"/>
                        <ObjectStatus
                          text="{view>gazetteExpiryUrgency}"
                          state="{path:'view>gazetteExpiryUrgency', formatter:'.fmtUrgencyState'}"/>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
                <Link text="View all compliance issues →" press=".onNavigateGazette" class="dashboardIndicatorLink sapUiTinyMarginTop" />
              </VBox>

            </FlexBox>

          </VBox>
        </ScrollContainer>
      </content>

    </Page>
  </App>
</mvc:View>
