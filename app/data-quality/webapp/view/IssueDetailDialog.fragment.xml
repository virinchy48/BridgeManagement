<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog
    id="issueDetailDialog"
    title="Bridge Issue Details"
    contentWidth="600px"
    resizable="true"
    draggable="true">

    <content>
      <VBox class="sapUiSmallMargin">

        <!-- Bridge header info -->
        <f:SimpleForm
          xmlns:f="sap.ui.layout.form"
          layout="ColumnLayout"
          columnsM="2" columnsL="2" columnsXL="2"
          editable="false">
          <f:content>
            <Label text="Bridge ID" />
            <Text id="detailBridgeId" text="" />

            <Label text="Bridge Name" />
            <Text id="detailBridgeName" text="" />

            <Label text="State" />
            <Text id="detailState" text="" />

            <Label text="Completeness Score" />
            <ProgressIndicator id="detailCompleteness"
              percentValue="0"
              displayValue="0%"
              state="None"
              showValue="true" />

            <Label text="Issues Found" />
            <Text id="detailIssueCount" text="" />
          </f:content>
        </f:SimpleForm>

        <Title text="Issue List" level="H4" class="sapUiSmallMarginTop sapUiSmallMarginBottom" />

        <!-- Issues list -->
        <List id="issueDetailList" mode="None" noDataText="No issues found.">
          <items>
            <CustomListItem>
              <VBox />
            </CustomListItem>
          </items>
        </List>

      </VBox>
    </content>

    <beginButton>
      <Button text="Close" press=".onCloseDetail" type="Emphasized" />
    </beginButton>
  </Dialog>

</core:FragmentDefinition>
