<mvc:View
  controllerName="BridgeManagement.dataquality.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:t="sap.ui.table"
  displayBlock="true">

  <App id="qualityApp">
    <Page
      id="qualityPage"
      title="Data Quality Dashboard"
      showHeader="true"
      class="sapUiResponsivePadding--header">

      <customHeader>
        <Bar>
          <contentLeft>
            <Title text="Data Quality Dashboard" level="H2" />
          </contentLeft>
          <contentRight>
            <Button icon="sap-icon://download" text="Export CSV" press=".onExportCsv" type="Transparent" />
            <Button icon="sap-icon://refresh" text="Refresh" press=".onRefresh" type="Transparent" />
          </contentRight>
        </Bar>
      </customHeader>

      <content>
        <VBox class="sapUiSmallMargin">

          <!-- KPI Summary Strip -->
          <HBox id="kpiStrip" wrap="Wrap" class="sapUiSmallMarginBottom">
            <GenericTile id="kpiTotalBridges"
              header="Total Bridges"
              class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
              press=".onKpiPress">
              <tileContent>
                <TileContent>
                  <content>
                    <NumericContent id="kpiTotalBridgesVal" value="0" scale="" withMargin="false"
                      icon="sap-icon://it-system" />
                  </content>
                </TileContent>
              </tileContent>
            </GenericTile>

            <GenericTile id="kpiIssuesFound"
              header="Bridges with Issues"
              class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
              press=".onKpiPress">
              <tileContent>
                <TileContent>
                  <content>
                    <NumericContent id="kpiIssuesFoundVal" value="0" scale="" withMargin="false"
                      icon="sap-icon://alert" />
                  </content>
                </TileContent>
              </tileContent>
            </GenericTile>

            <GenericTile id="kpiCritical"
              header="Critical Issues"
              class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
              press=".onKpiPress">
              <tileContent>
                <TileContent>
                  <content>
                    <NumericContent id="kpiCriticalVal" value="0" scale="" withMargin="false"
                      valueColor="Critical" icon="sap-icon://message-error" />
                  </content>
                </TileContent>
              </tileContent>
            </GenericTile>

            <GenericTile id="kpiCompleteness"
              header="Avg Completeness"
              class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
              press=".onKpiPress">
              <tileContent>
                <TileContent>
                  <content>
                    <NumericContent id="kpiCompletenessVal" value="0" scale="%" withMargin="false"
                      icon="sap-icon://quality-issue" />
                  </content>
                </TileContent>
              </tileContent>
            </GenericTile>
          </HBox>

          <!-- Filter Bar -->
          <Panel headerText="Filters" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
            <content>
              <f:SimpleForm layout="ColumnLayout" columnsM="2" columnsL="3" columnsXL="4" editable="true">
                <f:content>
                  <Label text="Severity" />
                  <Select id="filterSeverity" change=".onFilterChange" width="100%">
                    <items>
                      <core:Item key="" text="All Severities" />
                      <core:Item key="critical" text="Critical" />
                      <core:Item key="warning" text="Warning" />
                      <core:Item key="info" text="Info" />
                    </items>
                  </Select>

                  <Label text="State" />
                  <Input id="filterState" placeholder="e.g. NSW, VIC" liveChange=".onFilterChange" width="100%" />

                  <Label text="Bridge Name / ID" />
                  <Input id="filterName" placeholder="Search bridge name or ID" liveChange=".onFilterChange" width="100%" />
                </f:content>
              </f:SimpleForm>
              <HBox justifyContent="End" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
                <Button text="Reset Filters" press=".onResetFilters" type="Transparent" />
              </HBox>
            </content>
          </Panel>

          <!-- Issue Table -->
          <Panel expandable="false">
            <headerToolbar>
              <Toolbar>
                <Title text="Bridges with Data Issues" level="H3" />
                <ToolbarSpacer />
                <Text id="issueTableCount" text="" />
              </Toolbar>
            </headerToolbar>
            <content>
              <t:Table id="issueTable"
                visibleRowCount="15"
                selectionMode="None"
                enableBusyIndicator="true"
                noData="No bridges with data issues found for the current filters.">
                <t:columns>
                  <t:Column width="140px">
                    <Label text="Bridge ID" />
                    <t:template><Text text="{quality>bridgeId}" wrapping="false" /></t:template>
                  </t:Column>
                  <t:Column minWidth="200px">
                    <Label text="Bridge Name" />
                    <t:template><Text text="{quality>bridgeName}" /></t:template>
                  </t:Column>
                  <t:Column width="80px">
                    <Label text="State" />
                    <t:template><Text text="{quality>state}" wrapping="false" /></t:template>
                  </t:Column>
                  <t:Column width="100px">
                    <Label text="Issues" />
                    <t:template>
                      <ObjectNumber number="{quality>issueCount}" state="{quality>maxSeverityState}" emphasized="true" />
                    </t:template>
                  </t:Column>
                  <t:Column width="130px">
                    <Label text="Max Severity" />
                    <t:template>
                      <ObjectStatus text="{quality>maxSeverityLabel}" state="{quality>maxSeverityState}" icon="{quality>maxSeverityIcon}" />
                    </t:template>
                  </t:Column>
                  <t:Column width="180px">
                    <Label text="Completeness" />
                    <t:template>
                      <VBox class="bmsQualityScore">
                        <ProgressIndicator
                          percentValue="{quality>completenessScore}"
                          displayValue="{quality>completenessScore}%"
                          state="{quality>completenessState}"
                          showValue="true" />
                      </VBox>
                    </t:template>
                  </t:Column>
                  <t:Column width="120px">
                    <Label text="Actions" />
                    <t:template>
                      <Button text="View Details" press=".onViewDetails" type="Transparent" icon="sap-icon://detail-view" />
                    </t:template>
                  </t:Column>
                </t:columns>
              </t:Table>
            </content>
          </Panel>

        </VBox>
      </content>
    </Page>
  </App>

</mvc:View>
