<mvc:View
  controllerName="BridgeManagement.mapview.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  displayBlock="true"
  height="100%">

  <f:FlexibleColumnLayout
    id="fcl"
    layout="{view>/fclLayout}"
    backgroundDesign="Solid"
    class="nhvrMapApp">

    <f:beginColumnPages>
      <Page id="filterPage" backgroundDesign="Solid" class="nhvrSidebarPage">
        <customHeader>
          <Bar id="filterBar" class="nhvrTopBar">
            <contentLeft>
              <Button icon="sap-icon://building" tooltip="{i18n>fullRecord}" press=".onNavToBridgesFE" type="Transparent" />
              <Button icon="sap-icon://bar-chart" tooltip="Reports" press=".onNavToReports" type="Transparent" />
              <Button icon="sap-icon://upload-to-cloud" tooltip="Upload" press=".onNavToUpload" type="Transparent" />
              <Button icon="sap-icon://grid" tooltip="Mass Edit" press=".onNavToMassEdit" type="Transparent" />
            </contentLeft>
            <contentMiddle>
              <Title text="{i18n>filterTitle}" level="H4" />
            </contentMiddle>
          </Bar>
        </customHeader>

        <content>
          <VBox class="nhvrSidebar">
            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Base Map">
              <content>
                <List mode="SingleSelectMaster" showSeparators="None" class="nhvrBaseMapList">
                  <items>
                    <StandardListItem title="{i18n>basemapStreet}" type="Active" selected="{= ${view>/basemap} === 'street' }" press=".onBasemapChange">
                      <customData>
                        <core:CustomData key="basemap" value="street" />
                      </customData>
                    </StandardListItem>
                    <StandardListItem title="{i18n>basemapSatellite}" type="Active" selected="{= ${view>/basemap} === 'satellite' }" press=".onBasemapChange">
                      <customData>
                        <core:CustomData key="basemap" value="satellite" />
                      </customData>
                    </StandardListItem>
                  </items>
                </List>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Business Layers">
              <content>
                <VBox class="nhvrFilterSection">
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow">
                    <HBox alignItems="Center">
                      <CheckBox selected="true" enabled="false" />
                      <core:Icon src="sap-icon://map-2" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="Bridges" class="nhvrLayerLabel" />
                    </HBox>
                    <Button icon="sap-icon://zoom-in" type="Transparent" press=".onZoomAll" />
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow">
                    <HBox alignItems="Center">
                      <CheckBox selected="{view>/layers/clusterMarkers}" select=".onToggleClusterLayer" />
                      <core:Icon src="sap-icon://group-2" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="{i18n>clusterMarkers}" class="nhvrLayerLabel" />
                    </HBox>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow">
                    <HBox alignItems="Center">
                      <CheckBox selected="{view>/layers/showLabels}" select=".onToggleLabelLayer" />
                      <core:Icon src="sap-icon://tag" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="{i18n>showLabels}" class="nhvrLayerLabel" />
                    </HBox>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow">
                    <HBox alignItems="Center">
                      <CheckBox selected="{view>/layers/showHillshade}" select=".onToggleHillshadeLayer" />
                      <core:Icon src="sap-icon://map-3" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="{i18n>showHillshade}" class="nhvrLayerLabel" />
                    </HBox>
                  </HBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="{i18n>filters}">
              <content>
                <VBox class="nhvrFilterSection">
                  <Label text="{i18n>stateTerritory}" class="nhvrFilterLabel" />
                  <List items="{view>/filterOptions/states}" showSeparators="None">
                    <items>
                      <CustomListItem class="nhvrCompactFilterItem">
                        <CheckBox text="{view>label}" selected="{view>selected}" select=".onApplyFilters" />
                      </CustomListItem>
                    </items>
                  </List>

                  <Label text="{i18n>postingStatus}" class="nhvrFilterLabel nhvrFilterLabelTop" />
                  <List items="{view>/filterOptions/postingStatuses}" showSeparators="None">
                    <items>
                      <CustomListItem class="nhvrCompactFilterItem">
                        <CheckBox text="{view>label}" selected="{view>selected}" select=".onApplyFilters" />
                      </CustomListItem>
                    </items>
                  </List>

                  <Label text="{i18n>conditionRating}" class="nhvrFilterLabel nhvrFilterLabelTop" />
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrRangeRow">
                    <Label text="{i18n>min}" />
                    <StepInput value="{view>/filters/minCondition}" min="1" max="10" step="1" width="5rem" change=".onApplyFilters" />
                    <Label text="{i18n>max}" />
                    <StepInput value="{view>/filters/maxCondition}" min="1" max="10" step="1" width="5rem" change=".onApplyFilters" />
                  </HBox>

                  <HBox justifyContent="SpaceBetween" class="nhvrFilterActions">
                    <Button text="{i18n>clearAll}" icon="sap-icon://reset" press=".onClearFilters" />
                    <Button text="{i18n>applyFilters}" icon="sap-icon://search" type="Emphasized" press=".onApplyFilters" />
                  </HBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Legend &amp; Symbology">
              <content>
                <VBox class="nhvrFilterSection">
                  <Label text="Color by" class="nhvrFilterLabel" />
                  <SegmentedButton selectedKey="{view>/colorBy}" selectionChange=".onSymbologyChange" width="100%" class="nhvrSymbologyButton">
                    <items>
                      <SegmentedButtonItem key="status" text="{i18n>colorByStatus}" icon="sap-icon://status-positive" />
                      <SegmentedButtonItem key="condition" text="{i18n>colorByCondition}" icon="sap-icon://quality-issue" />
                    </items>
                  </SegmentedButton>

                  <VBox class="nhvrLegendItems" visible="{= ${view>/colorBy} === 'status' }">
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#2563eb'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>statusUnrestricted}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#f59e0b'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>statusPosted}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#ef4444'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>statusClosed}" class="nhvrLegendText" />
                    </HBox>
                  </VBox>

                  <VBox class="nhvrLegendItems" visible="{= ${view>/colorBy} === 'condition' }">
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#16a34a'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>conditionGood}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#f59e0b'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>conditionFair}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#ef4444'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>conditionPoor}" class="nhvrLegendText" />
                    </HBox>
                  </VBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel nhvrSelectionPanel" expandable="false" headerText="Spatial Selection" visible="{view>/selectionActive}">
              <content>
                <VBox class="nhvrFilterSection">
                  <ObjectStatus text="{view>/selectionLabel}" state="Information" inverted="true" />
                  <Text text="{= ${view>/selectionCount} + ' selected bridges' }" class="sapUiTinyMarginTop" />
                  <Button text="{i18n>clearSelection}" icon="sap-icon://clear-filter" press=".onClearSelection" class="sapUiTinyMarginTop" />
                </VBox>
              </content>
            </Panel>
          </VBox>
        </content>
      </Page>
    </f:beginColumnPages>

    <f:midColumnPages>
      <Page id="mapPage" backgroundDesign="Solid" busy="{view>/busy}" class="nhvrMapPage">
        <customHeader>
          <Bar id="mapBar" class="nhvrTopBar">
            <contentLeft>
              <Button icon="sap-icon://menu2" tooltip="{view>/panelToggleTooltip}" press=".onTogglePanel" type="Transparent" />
              <Title id="mapPageTitle" text="{i18n>appTitle}" level="H1" />
            </contentLeft>
            <contentMiddle>
              <SearchField width="20rem" placeholder="{i18n>bridgeName}" search=".onSearchBridge" liveChange=".onSearchLiveChange" />
            </contentMiddle>
            <contentRight>
              <ObjectStatus text="{view>/bridgeCountText}" state="Information" />
              <Button text="Spatial Select" icon="sap-icon://map-2" press=".onToggleDrawToolbar" type="{= ${view>/drawToolbarVisible} ? 'Emphasized' : 'Default' }" />
              <ToggleButton text="{i18n>layoutList}" icon="sap-icon://list" pressed="{view>/showList}" press=".onToggleSplitView" type="Transparent" />
              <Button icon="sap-icon://full-screen" tooltip="{i18n>centerMap}" press=".onZoomAll" type="Transparent" />
              <Button icon="sap-icon://resize" tooltip="Zoom to selection" press=".onZoomSelected" enabled="{view>/selectionActive}" type="Transparent" />
              <Button icon="sap-icon://refresh" tooltip="{i18n>refresh}" press=".onRefresh" type="Transparent" />
            </contentRight>
          </Bar>
        </customHeader>

        <content>
          <VBox id="mapBodyBox" height="100%" class="nhvrMapBody">
            <Toolbar visible="{view>/drawToolbarVisible}" design="Solid" class="nhvrDrawToolbar">
              <Text text="Draw a spatial selection on the map" />
              <ToolbarSpacer />
              <Button text="{i18n>drawPolygon}" icon="sap-icon://map-2" press=".onDrawPolygon" />
              <Button text="{i18n>drawRectangle}" icon="sap-icon://border" press=".onDrawRectangle" />
              <Button text="{i18n>drawCircle}" icon="sap-icon://circle-task" press=".onDrawCircle" />
              <Button text="{i18n>clearSelection}" icon="sap-icon://eraser" press=".onClearSelection" />
              <ToolbarSeparator />
              <Button icon="sap-icon://decline" tooltip="Close draw tools" press=".onCloseDrawToolbar" type="Transparent" />
            </Toolbar>

            <VBox class="nhvrMapHostShell">
              <VBox id="mapHost" class="bridgeMapCanvas" />
            </VBox>

            <Toolbar design="Transparent" height="28px" visible="{= !!${view>/coordinateText} }" class="nhvrCoordinateBar">
              <ToolbarSpacer />
              <Text text="{view>/coordinateText}" class="nhvrCoordinateText" />
            </Toolbar>

            <VBox visible="{view>/showList}" class="nhvrListPanel">
              <Toolbar class="nhvrVariantBar">
                <Text text="View:" class="nhvrVariantLabel" />
                <Select width="10rem" selectedKey="standard">
                  <items>
                    <core:Item key="standard" text="Standard" />
                  </items>
                </Select>
                <ToolbarSpacer />
                <ObjectStatus text="{view>/listTitleText}" state="Information" />
              </Toolbar>

              <Toolbar design="Solid" class="nhvrListToolbar">
                <SearchField width="14rem" placeholder="{i18n>bridgeName}" search=".onListSearch" liveChange=".onListSearchLive" />
                <ToolbarSpacer />
                <Button icon="sap-icon://full-screen" tooltip="{i18n>centerMap}" press=".onZoomAll" type="Transparent" />
              </Toolbar>

              <Table
                id="bridgeList"
                items="{view>/bridges}"
                growing="true"
                growingThreshold="50"
                alternateRowColors="true"
                sticky="ColumnHeaders"
                noDataText="{i18n>noBridges}">
                <columns>
                  <Column><Text text="{i18n>bridgeName}" /></Column>
                  <Column width="8rem" demandPopin="true" minScreenWidth="Large"><Text text="{i18n>bridgeId}" /></Column>
                  <Column width="7rem" demandPopin="true" minScreenWidth="Tablet"><Text text="{i18n>stateTerritory}" /></Column>
                  <Column width="10rem"><Text text="{i18n>postingStatus}" /></Column>
                  <Column width="8rem" demandPopin="true" minScreenWidth="Tablet"><Text text="{i18n>conditionRating}" /></Column>
                  <Column width="11rem" demandPopin="true" minScreenWidth="Large"><Text text="{i18n>structureType}" /></Column>
                  <Column width="7rem" demandPopin="true" minScreenWidth="Large"><Text text="{i18n>yearBuilt}" /></Column>
                  <Column width="5rem" hAlign="End"><Text text="" /></Column>
                </columns>
                <items>
                  <ColumnListItem type="Navigation" press=".onListItemPress">
                    <cells>
                      <Text text="{view>bridgeName}" maxLines="1" wrapping="false" />
                      <Text text="{view>bridgeId}" />
                      <Text text="{view>state}" />
                      <ObjectStatus text="{view>postingStatusLabel}" state="{view>postingStatusState}" />
                      <ObjectStatus text="{view>conditionRating}" state="{view>conditionState}" />
                      <Text text="{view>structureType}" />
                      <Text text="{view>yearBuilt}" />
                      <Button icon="sap-icon://detail-view" tooltip="{i18n>zoomToBridge}" press=".onListItemDetail" type="Transparent" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </VBox>
        </content>
      </Page>
    </f:midColumnPages>
  </f:FlexibleColumnLayout>
</mvc:View>
