<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog id="featureDetailDialog"
          contentWidth="380px"
          resizable="false"
          draggable="true"
          verticalScrolling="false"
          showHeader="false"
          class="nhvrDetailDialog">

    <content>
      <!-- Custom header with X button always visible -->
      <VBox class="nhvrDlgHeader">
        <HBox justifyContent="SpaceBetween" alignItems="Center" class="nhvrDlgHeaderRow">
          <VBox class="nhvrDlgHeaderText">
            <Title text="{= ${view>/selectedFeature/type} === 'restriction' ? ${view>/selectedFeature/data/restrictionType} : ${view>/selectedFeature/data/bridgeName} }"
                   level="H5" wrapping="true" class="nhvrDlgTitle" />
            <!-- Bridge subtitle -->
            <HBox alignItems="Center" visible="{= ${view>/selectedFeature/type} === 'bridge' }" class="nhvrDlgSubtitle">
              <Text text="{view>/selectedFeature/data/bridgeId}" class="nhvrDlgId" />
              <Text text=" · " class="nhvrDlgSep" />
              <Text text="{view>/selectedFeature/data/state}" class="nhvrDlgSep" />
            </HBox>
            <!-- Restriction subtitle -->
            <HBox alignItems="Center" visible="{= ${view>/selectedFeature/type} === 'restriction' }" class="nhvrDlgSubtitle">
              <Text text="{view>/selectedFeature/data/bridgeName}" class="nhvrDlgId" />
              <Text text=" · " class="nhvrDlgSep" />
              <Text text="{view>/selectedFeature/data/restrictionRef}" class="nhvrDlgSep" />
            </HBox>
          </VBox>
          <Button icon="sap-icon://decline" type="Transparent" press=".onCloseFeaturePanel"
                  tooltip="Close" class="nhvrDlgCloseBtn" />
        </HBox>
        <!-- Status badges row -->
        <HBox class="nhvrDlgBadges" visible="{= ${view>/selectedFeature/type} === 'bridge' }">
          <ObjectStatus text="{view>/selectedFeature/data/postingStatusLabel}"
                        state="{view>/selectedFeature/data/postingStatusState}"
                        inverted="true" class="nhvrBadge" />
          <ObjectStatus text="{view>/selectedFeature/data/conditionBandLabel}"
                        state="{view>/selectedFeature/data/conditionState}"
                        class="nhvrBadge sapUiTinyMarginBegin" />
        </HBox>
        <HBox class="nhvrDlgBadges" visible="{= ${view>/selectedFeature/type} === 'restriction' }">
          <ObjectStatus text="{view>/selectedFeature/data/restrictionStatus}"
                        state="Warning" inverted="true" class="nhvrBadge" />
        </HBox>
      </VBox>

      <!-- Bridge body -->
      <VBox visible="{= ${view>/selectedFeature/type} === 'bridge' }" class="nhvrDlgBody">
        <!-- Coordinates -->
        <HBox alignItems="Center" class="nhvrDlgCoords">
          <core:Icon src="sap-icon://map" class="nhvrCoordsIcon" />
          <Text text="{view>/selectedFeature/data/coordinateText}" class="nhvrCoordsText" />
        </HBox>

        <!-- Metrics 2×2 grid -->
        <HBox class="nhvrMetricsGrid">
          <VBox class="nhvrMetricItem">
            <Text text="Condition" class="nhvrMetricLabel" />
            <ObjectStatus text="{view>/selectedFeature/data/metricRating}"
                          state="{view>/selectedFeature/data/conditionState}" class="nhvrMetricValue" />
          </VBox>
          <VBox class="nhvrMetricItem">
            <Text text="Clearance" class="nhvrMetricLabel" />
            <Text text="{view>/selectedFeature/data/metricClearance}" class="nhvrMetricValue" />
          </VBox>
          <VBox class="nhvrMetricItem">
            <Text text="Year Built" class="nhvrMetricLabel" />
            <Text text="{view>/selectedFeature/data/metricYear}" class="nhvrMetricValue" />
          </VBox>
          <VBox class="nhvrMetricItem">
            <Text text="Span" class="nhvrMetricLabel" />
            <Text text="{view>/selectedFeature/data/spanLengthText}" class="nhvrMetricValue" />
          </VBox>
        </HBox>
        <Text text="{view>/selectedFeature/data/structureType}" class="nhvrStructureType" />

        <!-- Restrictions -->
        <VBox visible="{= ${view>/selectedFeature/data/restrictions/length} > 0 }" class="nhvrDlgRestrictions">
          <Text text="Active Restrictions" class="nhvrRestrictionsLabel" />
          <List items="{view>/selectedFeature/data/restrictions}" showSeparators="None"
                backgroundDesign="Transparent">
            <items>
              <CustomListItem>
                <ObjectStatus text="{view>name}" state="Error" inverted="true"
                              class="nhvrBadge sapUiTinyMarginEnd" />
              </CustomListItem>
            </items>
          </List>
        </VBox>
      </VBox>

      <!-- Restriction body -->
      <VBox visible="{= ${view>/selectedFeature/type} === 'restriction' }" class="nhvrDlgBody">
        <HBox class="nhvrMetricsGrid">
          <VBox class="nhvrMetricItem" visible="{= !!${view>/selectedFeature/data/grossMassLimit} }">
            <Text text="Gross Mass" class="nhvrMetricLabel" />
            <Text text="{view>/selectedFeature/data/grossMassLimit} t" class="nhvrMetricValue" />
          </VBox>
          <VBox class="nhvrMetricItem" visible="{= !!${view>/selectedFeature/data/heightLimit} }">
            <Text text="Height Limit" class="nhvrMetricLabel" />
            <Text text="{view>/selectedFeature/data/heightLimit} m" class="nhvrMetricValue" />
          </VBox>
          <VBox class="nhvrMetricItem" visible="{= !!${view>/selectedFeature/data/speedLimit} }">
            <Text text="Speed Limit" class="nhvrMetricLabel" />
            <Text text="{view>/selectedFeature/data/speedLimit} km/h" class="nhvrMetricValue" />
          </VBox>
        </HBox>
        <HBox class="nhvrPermitRow">
          <ObjectStatus text="Permit Required" state="Warning" inverted="false"
                        visible="{view>/selectedFeature/data/permitRequired}" class="nhvrBadge" />
          <ObjectStatus text="Escort Required" state="Error" inverted="false"
                        visible="{view>/selectedFeature/data/escortRequired}"
                        class="nhvrBadge sapUiTinyMarginBegin" />
        </HBox>
      </VBox>
    </content>

    <!-- Footer actions -->
    <beginButton>
      <Button text="View Bridge on Map" icon="sap-icon://map-2"
              type="Emphasized" press=".onViewBridgeFromRestriction"
              visible="{= ${view>/selectedFeature/type} === 'restriction' }" />
    </beginButton>
    <buttons>
      <Button text="Zoom to Bridge" icon="sap-icon://zoom-in"
              type="Emphasized" press=".onZoomToSelected"
              visible="{= ${view>/selectedFeature/type} === 'bridge' }" />
      <Button text="Open in Register" icon="sap-icon://open-command-field"
              press=".onOpenInBridgeRegister" />
    </buttons>

  </Dialog>

</core:FragmentDefinition>
