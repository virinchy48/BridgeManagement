{
  "_version": "1.8.0",
  "sap.app": {
    "id": "BridgeManagement.mapview",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "crossNavigation": {
      "inbounds": {
        "Map-display": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "Map",
          "action": "display",
          "title": "{{appTitle}}",
          "info": "{{appDescription}}",
          "subTitle": "{{appSubTitle}}",
          "icon": "sap-icon://map-2"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "deviceTypes": {
      "desktop": true,
      "phone": true,
      "tablet": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.f": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "routes": [
        {
          "pattern": "",
          "name": "Main",
          "target": "Main"
        }
      ],
      "targets": {
        "Main": {
          "viewType": "XML",
          "viewName": "BridgeManagement.mapview.view.Main",
          "viewId": "Main"
        }
      }
    },
    "rootView": {
      "viewName": "BridgeManagement.mapview.view.Main",
      "type": "XML",
      "async": true,
      "id": "Main"
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
