<mvc:View
  controllerName="BridgeManagement.mapview.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  displayBlock="true"
  height="100%">

  <f:FlexibleColumnLayout
    id="fcl"
    layout="{view>/fclLayout}"
    backgroundDesign="Solid"
    class="nhvrMapApp">

    <f:beginColumnPages>
      <Page id="filterPage" backgroundDesign="Solid" class="nhvrSidebarPage">
        <customHeader>
          <Bar id="filterBar" class="nhvrTopBar">
            <contentLeft>
              <Button icon="sap-icon://building" tooltip="{i18n>fullRecord}" press=".onNavToBridgesFE" type="Transparent" />
              <Button icon="sap-icon://bar-chart" tooltip="Reports" press=".onNavToReports" type="Transparent" />
              <Button icon="sap-icon://upload-to-cloud" tooltip="Upload" press=".onNavToUpload" type="Transparent" />
              <Button icon="sap-icon://grid" tooltip="Mass Edit" press=".onNavToMassEdit" type="Transparent" />
            </contentLeft>
            <contentMiddle>
              <Title text="{i18n>filterTitle}" level="H4" />
            </contentMiddle>
          </Bar>
        </customHeader>

        <content>
          <VBox class="nhvrSidebar">
            <!-- Demo Mode Banner -->
            <MessageStrip
              id="demoBanner"
              text="🎯  DEMO MODE: Showing 30 real NSW bridges from the Transport for NSW public dataset. Data is for demonstration only."
              type="Warning"
              showIcon="true"
              showCloseButton="false"
              visible="{view>/demoModeActive}"
              class="sapUiTinyMarginBottom" />

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Base Map">
              <content>
                <VBox class="nhvrFilterSection nhvrBasemapSection">
                  <!-- Streets group -->
                  <Text text="STREETS" class="nhvrBasemapGroupLabel" />
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://map" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="OpenStreetMap" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'osm' || ${view>/basemap} === 'street' }">
                      <customData><core:CustomData key="basemap" value="osm" /></customData>
                    </RadioButton>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://journey-arrive" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="Esri Street" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'esriStreet' }">
                      <customData><core:CustomData key="basemap" value="esriStreet" /></customData>
                    </RadioButton>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://map-2" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="Google Maps" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'google' }">
                      <customData><core:CustomData key="basemap" value="google" /></customData>
                    </RadioButton>
                  </HBox>
                  <!-- Imagery group -->
                  <Text text="IMAGERY" class="nhvrBasemapGroupLabel" />
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://globe" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="Esri Satellite" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'esriSatellite' || ${view>/basemap} === 'satellite' }">
                      <customData><core:CustomData key="basemap" value="esriSatellite" /></customData>
                    </RadioButton>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://world" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="Google Satellite" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'googleSat' }">
                      <customData><core:CustomData key="basemap" value="googleSat" /></customData>
                    </RadioButton>
                  </HBox>
                  <!-- Terrain / Other group -->
                  <Text text="TERRAIN &amp; OTHER" class="nhvrBasemapGroupLabel" />
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://mountain" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="Esri Topo" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'esriTopo' }">
                      <customData><core:CustomData key="basemap" value="esriTopo" /></customData>
                    </RadioButton>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrBasemapRow">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://pushpin-on" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="HERE Maps" class="nhvrLayerLabel" />
                    </HBox>
                    <RadioButton groupName="basemapGroup" select=".onBasemapChange"
                      selected="{= ${view>/basemap} === 'here' }">
                      <customData><core:CustomData key="basemap" value="here" /></customData>
                    </RadioButton>
                  </HBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Reference Layers">
              <content>
                <VBox class="nhvrFilterSection">
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow"
                        visible="{view>/features/showStateBoundaries}">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://world" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="State &amp; Territory Boundaries" class="nhvrLayerLabel" />
                    </HBox>
                    <Switch state="{view>/layers/refLayers/stateBoundaries}" change=".onToggleRefLayer">
                      <customData><core:CustomData key="layerKey" value="stateBoundaries" /></customData>
                    </Switch>
                  </HBox>
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow"
                        visible="{view>/features/showLgaBoundaries}">
                    <HBox alignItems="Center">
                      <core:Icon src="sap-icon://geographic-bubble-chart" size="0.875rem" class="nhvrLayerIcon" />
                      <Text text="LGA Boundaries (ABS ASGS)" class="nhvrLayerLabel" />
                    </HBox>
                    <Switch state="{view>/layers/refLayers/lgaBoundaries}" change=".onToggleRefLayer">
                      <customData><core:CustomData key="layerKey" value="lgaBoundaries" /></customData>
                    </Switch>
                  </HBox>
                  <Text text="Source: ABS ASGS 2021" class="nhvrLayerHint sapUiTinyMarginTop"
                        visible="{= ${view>/features/showStateBoundaries} || ${view>/features/showLgaBoundaries} }" />

                  <!-- Dynamic reference layers loaded from GIS Config admin -->
                  <VBox visible="{= ${view>/dynRefGroups}.length > 0 }">
                    <Text text="ADDITIONAL LAYERS" class="nhvrBasemapGroupLabel sapUiSmallMarginTop" />
                    <List items="{view>/dynRefGroups}" showSeparators="None" backgroundDesign="Transparent">
                      <items>
                        <CustomListItem>
                          <VBox>
                            <Text text="{view>category}" class="nhvrRefLayerCatHeader" />
                            <List items="{view>items}" showSeparators="None" backgroundDesign="Transparent">
                              <items>
                                <CustomListItem>
                                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow">
                                    <VBox class="nhvrGisToolLabel">
                                      <Text text="{view>name}" class="nhvrLayerLabel" />
                                      <Text text="{view>description}" class="nhvrGisToolHint" maxLines="2" />
                                    </VBox>
                                    <Switch state="{view>sessionActive}" change=".onToggleDynamicRefLayer">
                                      <customData><core:CustomData key="layerId" value="{view>ID}" /></customData>
                                    </Switch>
                                  </HBox>
                                </CustomListItem>
                              </items>
                            </List>
                          </VBox>
                        </CustomListItem>
                      </items>
                    </List>
                  </VBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Business Layers">
              <content>
                <VBox class="nhvrFilterSection">
                  <!-- Bridges Layer -->
                  <VBox class="nhvrLayerGroup">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerGroupHeader">
                      <HBox alignItems="Center">
                        <CheckBox selected="{view>/layers/bridges/visible}" select=".onToggleBridgeLayer" />
                        <core:Icon src="sap-icon://map-2" size="1rem" class="nhvrLayerIcon" />
                        <Title text="Bridges" level="H6" class="nhvrLayerGroupTitle" />
                      </HBox>
                      <Text text="{view>/layers/bridges/count} bridges" class="nhvrLayerCount" />
                    </HBox>
                    <VBox class="nhvrLayerSubOptions" visible="{view>/layers/bridges/visible}">
                      <Text text="Display options" class="nhvrSubOptionsHeader" />
                      <VBox class="nhvrSubOptionsBody">
                        <CheckBox text="{i18n>clusterMarkers}" selected="{view>/layers/bridges/cluster}" select=".onToggleBridgeCluster" class="nhvrLayerSubOption" />
                        <CheckBox text="{i18n>showLabels}" selected="{view>/layers/bridges/showLabels}" select=".onToggleBridgeLabels" class="nhvrLayerSubOption" />
                        <HBox alignItems="Center" class="nhvrLayerSubOption nhvrColorByRow">
                          <Label text="Color by:" class="nhvrLayerSubLabel" />
                          <SegmentedButton selectedKey="{view>/layers/bridges/colorBy}" selectionChange=".onBridgeColorByChange" class="nhvrLayerColorBy">
                            <items>
                              <SegmentedButtonItem key="condition" text="Condition" />
                              <SegmentedButtonItem key="status" text="Status" />
                            </items>
                          </SegmentedButton>
                        </HBox>
                      </VBox>
                    </VBox>
                  </VBox>

                  <!-- Restrictions Layer -->
                  <VBox class="nhvrLayerGroup">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerGroupHeader">
                      <HBox alignItems="Center">
                        <CheckBox selected="{view>/layers/restrictions/visible}" select=".onToggleRestrictionLayer" />
                        <core:Icon src="sap-icon://warning" size="1rem" class="nhvrLayerIcon nhvrLayerIconWarning" />
                        <Title text="Restrictions" level="H6" class="nhvrLayerGroupTitle" />
                      </HBox>
                      <Text text="{view>/layers/restrictions/count} active" class="nhvrLayerCount" />
                    </HBox>
                    <VBox class="nhvrLayerSubOptions" visible="{view>/layers/restrictions/visible}">
                      <Text text="Active restrictions shown at bridge locations." class="nhvrLayerHint" />
                    </VBox>
                  </VBox>

                  <!-- Terrain -->
                  <VBox class="nhvrLayerGroup">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerGroupHeader">
                      <HBox alignItems="Center">
                        <core:Icon src="sap-icon://map-3" size="1rem" class="nhvrLayerIcon" />
                        <Title text="Terrain Hillshade" level="H6" class="nhvrLayerGroupTitle" />
                      </HBox>
                      <Switch state="{view>/layers/showHillshade}" change=".onToggleHillshadeLayer" />
                    </HBox>
                  </VBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="false" headerText="{i18n>filters}">
              <content>
                <VBox class="nhvrFilterSection">
                  <Label text="{i18n>stateTerritory}" class="nhvrFilterLabel" />
                  <List items="{view>/filterOptions/states}" showSeparators="None">
                    <items>
                      <CustomListItem class="nhvrCompactFilterItem">
                        <CheckBox text="{view>label}" selected="{view>selected}" select=".onApplyFilters" />
                      </CustomListItem>
                    </items>
                  </List>

                  <Label text="{i18n>postingStatus}" class="nhvrFilterLabel nhvrFilterLabelTop" />
                  <List items="{view>/filterOptions/postingStatuses}" showSeparators="None">
                    <items>
                      <CustomListItem class="nhvrCompactFilterItem">
                        <CheckBox text="{view>label}" selected="{view>selected}" select=".onApplyFilters" />
                      </CustomListItem>
                    </items>
                  </List>

                  <Label text="{i18n>conditionRating}" class="nhvrFilterLabel nhvrFilterLabelTop" />
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrRangeRow">
                    <Label text="{i18n>min}" />
                    <StepInput value="{view>/filters/minCondition}" min="1" max="10" step="1" width="5rem" change=".onApplyFilters" />
                    <Label text="{i18n>max}" />
                    <StepInput value="{view>/filters/maxCondition}" min="1" max="10" step="1" width="5rem" change=".onApplyFilters" />
                  </HBox>

                  <HBox justifyContent="SpaceBetween" class="nhvrFilterActions">
                    <Button text="{i18n>clearAll}" icon="sap-icon://reset" press=".onClearFilters" />
                    <Button text="{i18n>applyFilters}" icon="sap-icon://search" type="Emphasized" press=".onApplyFilters" />
                  </HBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel" expandable="true" expanded="false" headerText="Legend &amp; Symbology">
              <content>
                <VBox class="nhvrFilterSection">
                  <Label text="Color by" class="nhvrFilterLabel" />
                  <SegmentedButton selectedKey="{view>/colorBy}" selectionChange=".onSymbologyChange" width="100%" class="nhvrSymbologyButton">
                    <items>
                      <SegmentedButtonItem key="status" text="{i18n>colorByStatus}" icon="sap-icon://status-positive" />
                      <SegmentedButtonItem key="condition" text="{i18n>colorByCondition}" icon="sap-icon://quality-issue" />
                    </items>
                  </SegmentedButton>

                  <VBox class="nhvrLegendItems" visible="{= ${view>/colorBy} === 'status' }">
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#2563eb'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>statusUnrestricted}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#f59e0b'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>statusRestricted}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#ef4444'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>statusClosed}" class="nhvrLegendText" />
                    </HBox>
                  </VBox>

                  <VBox class="nhvrLegendItems" visible="{= ${view>/colorBy} === 'condition' }">
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#16a34a'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>conditionGood}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#f59e0b'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>conditionFair}" class="nhvrLegendText" />
                    </HBox>
                    <HBox alignItems="Center" class="nhvrLegendRow">
                      <core:HTML content="&lt;span class='nhvrLegendDot' style='background:#ef4444'&gt;&lt;/span&gt;" />
                      <Text text="{i18n>conditionPoor}" class="nhvrLegendText" />
                    </HBox>
                  </VBox>
                </VBox>
              </content>
            </Panel>

            <!-- Advanced GIS Tools -->
            <Panel class="nhvrSidebarPanel" expandable="true" expanded="false">
              <headerToolbar>
                <OverflowToolbar>
                  <Title text="GIS Tools" level="H6" class="nhvrPanelToolbarTitle" />
                  <ToolbarSpacer />
                  <Button icon="sap-icon://information" tooltip="How GIS Tools work" press=".onGisToolsHelp"
                          type="Transparent" class="nhvrInfoBtn" />
                </OverflowToolbar>
              </headerToolbar>
              <content>
                <VBox class="nhvrFilterSection">
                  <!-- Heat Map -->
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrGisToolRow" visible="{view>/features/heatmap}">
                    <VBox class="nhvrGisToolLabel">
                      <HBox alignItems="Center">
                        <core:Icon src="sap-icon://temperature" size="0.875rem" class="nhvrLayerIcon" />
                        <Text text="Heat Map" class="nhvrLayerLabel" />
                      </HBox>
                      <Text text="Density overlay by condition rating" class="nhvrGisToolHint" />
                    </VBox>
                    <Switch state="{view>/heatmapActive}" change=".onToggleHeatmap" />
                  </HBox>
                  <!-- Condition Alerts -->
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrGisToolRow" visible="{view>/features/conditionAlerts}">
                    <VBox class="nhvrGisToolLabel">
                      <HBox alignItems="Center">
                        <core:Icon src="sap-icon://alert" size="0.875rem" class="nhvrLayerIcon nhvrLayerIconWarning" />
                        <Text text="Condition Alerts" class="nhvrLayerLabel" />
                      </HBox>
                      <Text text="Highlights bridges below alert threshold" class="nhvrGisToolHint" />
                    </VBox>
                    <Switch state="{view>/conditionAlertsActive}" change=".onToggleConditionAlerts" />
                  </HBox>
                  <!-- Minimap -->
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrGisToolRow" visible="{view>/features/minimap}">
                    <VBox class="nhvrGisToolLabel">
                      <HBox alignItems="Center">
                        <core:Icon src="sap-icon://map-3" size="0.875rem" class="nhvrLayerIcon" />
                        <Text text="Mini Map" class="nhvrLayerLabel" />
                      </HBox>
                      <Text text="Overview inset map (bottom-right)" class="nhvrGisToolHint" />
                    </VBox>
                    <Switch state="{view>/minimapActive}" change=".onToggleMinimap" />
                  </HBox>
                  <!-- Viewport loading -->
                  <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrLayerRow nhvrGisToolRow">
                    <VBox class="nhvrGisToolLabel">
                      <HBox alignItems="Center">
                        <core:Icon src="sap-icon://show" size="0.875rem" class="nhvrLayerIcon" />
                        <Text text="Viewport Loading" class="nhvrLayerLabel" />
                      </HBox>
                      <Text text="Load only bridges in the current view" class="nhvrGisToolHint" />
                    </VBox>
                    <Switch state="{view>/viewportMode}" change=".onToggleViewportMode" />
                  </HBox>
                </VBox>
              </content>
            </Panel>

            <!-- Proximity Analysis -->
            <Panel class="nhvrSidebarPanel" expandable="true" expanded="false" headerText="Proximity Analysis"
                   visible="{view>/features/proximity}">
              <content>
                <VBox class="nhvrFilterSection">
                  <Text text="Find bridges within a radius of a point." class="nhvrLayerHint sapUiSmallMarginBottom" />
                  <Button icon="sap-icon://locate-me"
                          text="Near Me"
                          tooltip="Use your current device location"
                          press=".onGeolocate"
                          busy="{view>/proximity/geolocating}"
                          class="sapUiTinyMarginBottom" />
                  <Label text="Latitude" class="nhvrFilterLabel" />
                  <Input id="proxLat" value="{view>/proximity/lat}" placeholder="-33.8688" width="100%" />
                  <Label text="Longitude" class="nhvrFilterLabel nhvrFilterLabelTop" />
                  <Input id="proxLng" value="{view>/proximity/lng}" placeholder="151.2093" width="100%" />
                  <Label text="Radius (km)" class="nhvrFilterLabel nhvrFilterLabelTop" />
                  <StepInput id="proxRadius" value="{view>/proximity/radius}" min="1" max="500" step="5" width="100%" />
                  <HBox justifyContent="SpaceBetween" class="nhvrFilterActions">
                    <Button text="Clear" icon="sap-icon://clear-filter" press=".onClearProximity"
                            enabled="{view>/proximity/active}" />
                    <Button text="Find Bridges" icon="sap-icon://locate-me" type="Emphasized"
                            press=".onRunProximity" busy="{view>/proximity/loading}" />
                  </HBox>
                  <ObjectStatus
                    visible="{view>/proximity/active}"
                    text="{= ${view>/proximity/count} + ' bridges within radius' }"
                    state="Success"
                    class="sapUiTinyMarginTop" />
                </VBox>
              </content>
            </Panel>

            <!-- Time Slider -->
            <Panel class="nhvrSidebarPanel" expandable="true" expanded="false" headerText="Time Slider (Year Built)"
                   visible="{view>/features/timeSlider}">
              <content>
                <VBox class="nhvrFilterSection">
                  <Text text="{= 'Year: ' + ${view>/timeSlider/fromYear} + ' – ' + ${view>/timeSlider/toYear} }"
                        class="nhvrLayerHint" />
                  <RangeSlider
                    id="timeSlider"
                    min="1900"
                    max="2030"
                    value="{view>/timeSlider/fromYear}"
                    value2="{view>/timeSlider/toYear}"
                    showAdvancedTooltip="true"
                    enableTickmarks="false"
                    step="1"
                    width="100%"
                    change=".onTimeSliderChange"
                    class="sapUiSmallMarginTop" />
                  <Button text="Reset" icon="sap-icon://reset" press=".onResetTimeSlider"
                          visible="{view>/timeSlider/active}" class="sapUiTinyMarginTop" />
                </VBox>
              </content>
            </Panel>

            <!-- Statistics Panel -->
            <Panel class="nhvrSidebarPanel" expandable="true" expanded="true" headerText="Statistics"
                   visible="{view>/features/statsPanel}">
              <content>
                <VBox class="nhvrFilterSection">
                  <HBox class="nhvrStatsRow">
                    <VBox class="nhvrStatCard">
                      <ObjectNumber number="{view>/stats/total}" emphasized="true" />
                      <Text text="Visible" class="nhvrStatLabel" />
                    </VBox>
                    <VBox class="nhvrStatCard">
                      <ObjectNumber number="{view>/stats/avgCondition}" emphasized="true" state="Success" />
                      <Text text="Avg Condition" class="nhvrStatLabel" />
                    </VBox>
                  </HBox>
                  <HBox class="nhvrStatsRow">
                    <VBox class="nhvrStatCard">
                      <ObjectNumber number="{view>/stats/poor}" emphasized="true" state="Error" />
                      <Text text="Poor Condition" class="nhvrStatLabel" />
                    </VBox>
                    <VBox class="nhvrStatCard">
                      <ObjectNumber number="{view>/stats/restricted}" emphasized="true" state="Warning" />
                      <Text text="Restricted" class="nhvrStatLabel" />
                    </VBox>
                    <VBox class="nhvrStatCard">
                      <ObjectNumber number="{view>/stats/closed}" emphasized="true" state="Error" />
                      <Text text="Closed" class="nhvrStatLabel" />
                    </VBox>
                  </HBox>
                </VBox>
              </content>
            </Panel>

            <Panel class="nhvrSidebarPanel nhvrSelectionPanel" expandable="false" headerText="Spatial Selection" visible="{view>/selectionActive}">
              <content>
                <VBox class="nhvrFilterSection">
                  <ObjectStatus text="{view>/selectionLabel}" state="Information" inverted="true" />
                  <Text text="{= ${view>/selectionCount} + ' selected bridges' }" class="sapUiTinyMarginTop" />
                  <Button text="{i18n>clearSelection}" icon="sap-icon://clear-filter" press=".onClearSelection" class="sapUiTinyMarginTop" />
                </VBox>
              </content>
            </Panel>
          </VBox>
        </content>
      </Page>
    </f:beginColumnPages>

    <f:midColumnPages>
      <Page id="mapPage" backgroundDesign="Solid" busy="{view>/busy}" class="nhvrMapPage">
        <customHeader>
          <Bar id="mapBar" class="nhvrTopBar">
            <contentLeft>
              <Button icon="sap-icon://menu2" tooltip="{view>/panelToggleTooltip}" press=".onTogglePanel" type="Transparent" />
              <Title id="mapPageTitle" text="{i18n>appTitle}" level="H1" />
            </contentLeft>
            <contentMiddle>
              <SearchField width="20rem" placeholder="{i18n>bridgeName}" search=".onSearchBridge" liveChange=".onSearchLiveChange" />
            </contentMiddle>
            <contentRight>
              <ObjectStatus text="{view>/bridgeCountText}" state="Information" />
              <MenuButton text="Export" icon="sap-icon://download" type="Default" buttonMode="Split" defaultAction=".onExport">
                <menu>
                  <Menu>
                    <items>
                      <MenuItem text="Bridges: GeoJSON" press=".onExport">
                        <customData><core:CustomData key="export" value="bridges-geojson" /></customData>
                      </MenuItem>
                      <MenuItem text="Bridges: CSV" press=".onExport">
                        <customData><core:CustomData key="export" value="bridges-csv" /></customData>
                      </MenuItem>
                      <MenuItem text="Restrictions: GeoJSON" press=".onExport">
                        <customData><core:CustomData key="export" value="restrictions-geojson" /></customData>
                      </MenuItem>
                      <MenuItem text="Restrictions: CSV" press=".onExport">
                        <customData><core:CustomData key="export" value="restrictions-csv" /></customData>
                      </MenuItem>
                    </items>
                  </Menu>
                </menu>
              </MenuButton>
              <Button text="Spatial Select" icon="sap-icon://map-2" press=".onToggleDrawToolbar" type="{= ${view>/drawToolbarVisible} ? 'Emphasized' : 'Default' }" />
              <ToggleButton text="{i18n>layoutList}" icon="sap-icon://list" pressed="{view>/showList}" press=".onToggleSplitView" type="Transparent" />
              <Button icon="sap-icon://full-screen" tooltip="{i18n>centerMap}" press=".onZoomAll" type="Transparent" />
              <Button icon="sap-icon://resize" tooltip="Zoom to selection" press=".onZoomSelected" enabled="{view>/selectionActive}" type="Transparent" />
              <Button icon="sap-icon://refresh" tooltip="{i18n>refresh}" press=".onRefresh" type="Transparent" />
              <Button icon="sap-icon://share-2" text="Share" tooltip="Copy a link to the current map view" press=".onShareMap" type="Transparent" />
              <Button icon="sap-icon://information" tooltip="How map controls work" press=".onMapControlsHelp" type="Transparent" class="nhvrInfoBtn" />
            </contentRight>
          </Bar>
        </customHeader>

        <content>
          <VBox id="mapBodyBox" height="100%" class="nhvrMapBody">
            <Toolbar visible="{view>/drawToolbarVisible}" design="Solid" class="nhvrDrawToolbar">
              <Text text="Draw a spatial selection on the map" />
              <ToolbarSpacer />
              <Button text="{i18n>drawPolygon}" icon="sap-icon://map-2" press=".onDrawPolygon" />
              <Button text="{i18n>drawRectangle}" icon="sap-icon://border" press=".onDrawRectangle" />
              <Button text="{i18n>drawCircle}" icon="sap-icon://circle-task" press=".onDrawCircle" />
              <Button text="{i18n>clearSelection}" icon="sap-icon://eraser" press=".onClearSelection" />
              <ToolbarSeparator />
              <Button icon="sap-icon://decline" tooltip="Close draw tools" press=".onCloseDrawToolbar" type="Transparent" />
            </Toolbar>

            <VBox class="nhvrMapHostShell">
              <VBox id="mapHost" class="bridgeMapCanvas" />
            </VBox>

            <Toolbar design="Transparent" height="28px" visible="{= !!${view>/coordinateText} }" class="nhvrCoordinateBar">
              <ToolbarSpacer />
              <Text text="{view>/coordinateText}" class="nhvrCoordinateText" />
              <Text text="{view>/mgaCoords/text}"
                    visible="{= !!(${view>/features/mgaCoords} &amp;&amp; ${view>/mgaCoords/text}) }"
                    class="nhvrCoordinateText nhvrMgaCoords" />
            </Toolbar>

            <VBox visible="{view>/showList}" class="nhvrListPanel">
              <Toolbar class="nhvrVariantBar">
                <Text text="View:" class="nhvrVariantLabel" />
                <Select width="10rem" selectedKey="standard">
                  <items>
                    <core:Item key="standard" text="Standard" />
                  </items>
                </Select>
                <ToolbarSpacer />
                <ObjectStatus text="{view>/listTitleText}" state="Information" />
              </Toolbar>

              <Toolbar design="Solid" class="nhvrListToolbar">
                <SearchField width="14rem" placeholder="{i18n>bridgeName}" search=".onListSearch" liveChange=".onListSearchLive" />
                <ToolbarSpacer />
                <Button icon="sap-icon://full-screen" tooltip="{i18n>centerMap}" press=".onZoomAll" type="Transparent" />
              </Toolbar>

              <Table
                id="bridgeList"
                items="{view>/bridges}"
                growing="true"
                growingThreshold="50"
                alternateRowColors="true"
                sticky="ColumnHeaders"
                noDataText="{i18n>noBridges}">
                <columns>
                  <Column><Text text="{i18n>bridgeName}" /></Column>
                  <Column width="8rem" demandPopin="true" minScreenWidth="Large"><Text text="{i18n>bridgeId}" /></Column>
                  <Column width="7rem" demandPopin="true" minScreenWidth="Tablet"><Text text="{i18n>stateTerritory}" /></Column>
                  <Column width="10rem"><Text text="{i18n>postingStatus}" /></Column>
                  <Column width="8rem" demandPopin="true" minScreenWidth="Tablet"><Text text="{i18n>conditionRating}" /></Column>
                  <Column width="11rem" demandPopin="true" minScreenWidth="Large"><Text text="{i18n>structureType}" /></Column>
                  <Column width="7rem" demandPopin="true" minScreenWidth="Large"><Text text="{i18n>yearBuilt}" /></Column>
                  <Column width="5rem" hAlign="End"><Text text="" /></Column>
                </columns>
                <items>
                  <ColumnListItem type="Navigation" press=".onListItemPress">
                    <cells>
                      <Text text="{view>bridgeName}" maxLines="1" wrapping="false" />
                      <Text text="{view>bridgeId}" />
                      <Text text="{view>state}" />
                      <ObjectStatus text="{view>postingStatusLabel}" state="{view>postingStatusState}" />
                      <ObjectStatus text="{view>conditionRating}" state="{view>conditionState}" />
                      <Text text="{view>structureType}" />
                      <Text text="{view>yearBuilt}" />
                      <Button icon="sap-icon://detail-view" tooltip="{i18n>zoomToBridge}" press=".onListItemDetail" type="Transparent" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </VBox>
        </content>
      </Page>
    </f:midColumnPages>


  </f:FlexibleColumnLayout>
</mvc:View>
