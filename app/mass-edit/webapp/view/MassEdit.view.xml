<mvc:View
  controllerName="BridgeManagement.massedit.controller.MassEdit"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:t="sap.ui.table"
  displayBlock="true">

  <!--
    fitContent="true"  → DynamicPage hands height ownership to its content (the Table).
    The Table uses visibleRowCountMode="Auto" to fill whatever vertical space remains.
    MessageStrip is placed in t:infoToolbar (inside the table's own DOM) so its
    show/hide never triggers a DynamicPage reflow — that was the root cause of the
    "table disappears after first edit" bug.
  -->
  <!--
    fitContent omitted (defaults to false) so DynamicPage fills the viewport.
    The table uses visibleRowCountMode="Auto" and is the DIRECT child of f:content
    (no VBox wrapper), so it fills the remaining height automatically.
    The dirty-count banner lives inside t:extension — inside the table's own DOM —
    so toggling its visibility never causes a DynamicPage layout recalculation.
  -->
  <f:DynamicPage id="massEditPage" class="massEditPage" toggleHeaderOnTitleClick="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>massEdit}" level="H1"/>
        </f:heading>
        <f:actions>
          <Button text="{i18n>refresh}" icon="sap-icon://refresh" press="onRefresh"/>
          <Button
            text="{i18n>saveChanges}"
            icon="sap-icon://save"
            type="Emphasized"
            enabled="{= ${view>/dirtyCount} > 0 }"
            press="onSave"/>
          <Button
            text="{i18n>discard}"
            icon="sap-icon://undo"
            enabled="{= ${view>/dirtyCount} > 0 }"
            press="onDiscard"/>
          <Button icon="sap-icon://information" tooltip="How to use Mass Edit" type="Transparent" press="onShowHelp"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">

          <HBox wrap="Wrap" alignItems="Center" class="massEditFilterBar">
            <!-- OneWay so two-way binding does NOT write entityKey before selectionChange fires -->
            <SegmentedButton
              selectedKey="{path: 'view>/entityKey', mode: 'OneWay'}"
              selectionChange="onEntityTypeChange">
              <items>
                <SegmentedButtonItem key="BRIDGE"      text="{i18n>bridges}"      icon="sap-icon://building"  width="7.5rem"/>
                <SegmentedButtonItem key="RESTRICTION" text="{i18n>restrictions}" icon="sap-icon://alert"    width="9.5rem"/>
              </items>
            </SegmentedButton>

            <SearchField
              width="18rem"
              placeholder="{i18n>search}"
              value="{view>/filters/search}"
              liveChange="onFilterChange"/>

            <VBox visible="{view>/showStateFilter}">
              <Label text="{i18n>state}"/>
              <Select selectedKey="{view>/filters/state}" change="onFilterChange" width="10rem"
                      items="{view>/options/states}">
                <core:Item key="{view>key}" text="{view>text}"/>
              </Select>
            </VBox>

            <VBox visible="{view>/showStatusFilter}">
              <Label text="{view>/statusFilterLabel}"/>
              <Select selectedKey="{view>/filters/status}" change="onFilterChange" width="12rem"
                      items="{view>/statusFilterOptions}">
                <core:Item key="{view>key}" text="{view>text}"/>
              </Select>
            </VBox>

            <VBox>
              <Label text="{i18n>showChangedOnly}"/>
              <Switch state="{view>/filters/onlyDirty}" change="onFilterChange"/>
            </VBox>

            <Button
              text="{view>/bulkButtonText}"
              icon="sap-icon://multi-edit"
              press="onToggleBulkApply"/>
          </HBox>

          <Panel expandable="false" visible="{view>/bulkVisible}"
                 backgroundDesign="Transparent"
                 class="sapUiTinyMarginTop massEditBulkPanel">
            <content>
              <HBox wrap="Wrap" alignItems="Center" class="massEditBulkBar">
                <VBox>
                  <Label text="{i18n>field}"/>
                  <Select id="bulkFieldSelect" selectedKey="{view>/bulkFieldKey}"
                          change="onBulkFieldChange" width="14rem"
                          items="{view>/options/bulkFields}">
                    <core:Item key="{view>key}" text="{view>text}"/>
                  </Select>
                </VBox>

                <Input id="bulkValueInput" width="14rem"
                       visible="{= ${view>/bulkInputType} === 'text' || ${view>/bulkInputType} === 'number' || ${view>/bulkInputType} === 'decimal' }"/>
                <Select id="bulkValueSelect" width="14rem"
                        visible="{= ${view>/bulkInputType} === 'select' }"
                        items="{view>/options/bulkFieldOptions}">
                  <core:Item key="{view>key}" text="{view>text}"/>
                </Select>
                <DatePicker id="bulkValueDate" width="12rem"
                            valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                            visible="{= ${view>/bulkInputType} === 'date' }"/>
                <CheckBox id="bulkValueBool"
                          visible="{= ${view>/bulkInputType} === 'boolean' }"/>

                <Button text="{view>/applyButtonText}" type="Emphasized" press="onBulkApply"/>
              </HBox>
            </content>
          </Panel>

        </VBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <!--
        Table is the DIRECT child of f:content — no VBox wrapper.
        visibleRowCountMode="Auto" fills the remaining viewport height.
        Dirty message lives in infoToolbar (part of table's own layout),
        so toggling its visibility never affects the outer DynamicPage geometry.
      -->
      <t:Table
        id="massEditTable"
        rows="{path: 'view>/allItems'}"
        selectionMode="MultiToggle"
        selectionBehavior="RowSelector"
        rowSelectionChange="onTableSelectionChange"
        visibleRowCountMode="Fixed"
        visibleRowCount="18"
        rowHeight="40"
        fixedColumnCount="1"
        alternateRowColors="true"
        enableColumnReordering="true"
        busy="{view>/busy}"
        busyIndicatorDelay="200"
        threshold="50"
        class="massEditTable"
        noData="{i18n>noRecords}">

        <t:rowSettingsTemplate>
          <t:RowSettings highlight="{= ${view>_dirty} ? 'Warning' : 'None'}"/>
        </t:rowSettingsTemplate>

        <t:extension>
          <!-- Title bar: always visible -->
          <OverflowToolbar>
            <Title text="{view>/tableTitle}" level="H3"/>
            <ToolbarSpacer/>
            <Text text="{view>/summaryText}" class="sapUiSmallMarginEnd"/>
          </OverflowToolbar>
          <!--
            Dirty banner sits inside t:extension (inside the table's own DOM).
            Toggling its visibility does NOT affect the DynamicPage layout —
            this was the root cause of the "table disappears on first edit" bug.
          -->
          <Toolbar visible="{= ${view>/dirtyCount} > 0}" class="massEditInfoBar">
            <core:Icon src="sap-icon://message-warning"/>
            <Label text="{view>/dirtyMessage}" design="Bold"/>
          </Toolbar>
        </t:extension>

      </t:Table>
    </f:content>

  </f:DynamicPage>
</mvc:View>
