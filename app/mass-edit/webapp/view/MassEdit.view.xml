<mvc:View
  controllerName="BridgeManagement.massedit.controller.MassEdit"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:t="sap.ui.table"
  displayBlock="true">

  <f:DynamicPage id="massEditPage" class="massEditPage" toggleHeaderOnTitleClick="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>massEdit}" level="H1"/>
        </f:heading>

        <f:actions>
          <Button text="{i18n>refresh}" icon="sap-icon://refresh" press="onRefresh"/>
          <Button
            text="{i18n>saveChanges}"
            icon="sap-icon://save"
            type="Emphasized"
            enabled="{= ${view>/dirtyCount} > 0 }"
            press="onSave"/>
          <Button
            text="{i18n>discard}"
            icon="sap-icon://undo"
            enabled="{= ${view>/dirtyCount} > 0 }"
            press="onDiscard"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">
          <HBox wrap="Wrap" alignItems="Center" class="massEditFilterBar">
            <SegmentedButton selectedKey="{view>/entityKey}" selectionChange="onEntityTypeChange">
              <items>
                <SegmentedButtonItem key="BRIDGE" text="{i18n>bridges}" icon="sap-icon://building"/>
                <SegmentedButtonItem key="RESTRICTION" text="{i18n>restrictions}" icon="sap-icon://alert"/>
              </items>
            </SegmentedButton>

            <SearchField
              width="18rem"
              placeholder="{i18n>search}"
              value="{view>/filters/search}"
              liveChange="onFilterChange"/>

            <VBox visible="{view>/showStateFilter}">
              <Label text="{i18n>state}"/>
              <Select selectedKey="{view>/filters/state}" change="onFilterChange" width="10rem" items="{view>/options/states}">
                <core:Item key="{view>key}" text="{view>text}"/>
              </Select>
            </VBox>

            <VBox visible="{view>/showStatusFilter}">
              <Label text="{view>/statusFilterLabel}"/>
              <Select selectedKey="{view>/filters/status}" change="onFilterChange" width="12rem" items="{view>/statusFilterOptions}">
                <core:Item key="{view>key}" text="{view>text}"/>
              </Select>
            </VBox>

            <VBox>
              <Label text="{i18n>showChangedOnly}"/>
              <Switch state="{view>/filters/onlyDirty}" change="onFilterChange"/>
            </VBox>

            <Button
              text="{view>/bulkButtonText}"
              icon="sap-icon://multi-edit"
              press="onToggleBulkApply"/>
          </HBox>

          <Panel expandable="false" visible="{view>/bulkVisible}" backgroundDesign="Transparent" class="sapUiTinyMarginTop">
            <content>
              <HBox wrap="Wrap" alignItems="Center" class="massEditBulkBar">
                <VBox>
                  <Label text="{i18n>field}"/>
                  <Select id="bulkFieldSelect" selectedKey="{view>/bulkFieldKey}" change="onBulkFieldChange" width="14rem" items="{view>/options/bulkFields}">
                    <core:Item key="{view>key}" text="{view>text}"/>
                  </Select>
                </VBox>

                <Input id="bulkValueInput" width="14rem" visible="{= ${view>/bulkInputType} === 'text' || ${view>/bulkInputType} === 'number' || ${view>/bulkInputType} === 'decimal' }"/>
                <Select id="bulkValueSelect" width="14rem" visible="{= ${view>/bulkInputType} === 'select' }" items="{view>/options/bulkFieldOptions}">
                  <core:Item key="{view>key}" text="{view>text}"/>
                </Select>
                <DatePicker id="bulkValueDate" width="12rem" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" visible="{= ${view>/bulkInputType} === 'date' }"/>
                <CheckBox id="bulkValueBool" visible="{= ${view>/bulkInputType} === 'boolean' }"/>

                <Button
                  text="{view>/applyButtonText}"
                  type="Emphasized"
                  press="onBulkApply"/>
              </HBox>
            </content>
          </Panel>
        </VBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <VBox class="massEditShell">
        <MessageStrip text="{view>/dirtyMessage}" visible="{= ${view>/dirtyCount} > 0 }" type="Warning" showIcon="true"/>

        <t:Table
          id="massEditTable"
          rows="{view>/items}"
          selectionMode="MultiToggle"
          rowSelectionChange="onTableSelectionChange"
          visibleRowCountMode="Fixed"
          visibleRowCount="14"
          rowHeight="40"
          alternateRowColors="true"
          enableColumnReordering="true"
          busy="{view>/busy}"
          busyIndicatorDelay="0"
          class="massEditTable sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginBottom"
          noData="{i18n>noRecords}">
          <t:extension>
            <OverflowToolbar>
              <Title text="{view>/tableTitle}" level="H3"/>
              <ToolbarSpacer/>
              <Text text="{view>/summaryText}"/>
            </OverflowToolbar>
          </t:extension>
        </t:Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
