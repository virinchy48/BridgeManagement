<mvc:View
    controllerName="BridgeManagement.dashboard.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    displayBlock="true">
    <App id="app">
        <pages>
            <Page title="{i18n>appTitle}">
                <content>
                    <VBox class="sapUiMediumMargin">
                        <Title text="{i18n>appTitle}" level="H2" class="sapUiSmallMarginBottom"/>
                        <Text text="{i18n>appDescription}"/>
                    </VBox>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>
