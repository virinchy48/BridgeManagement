{
  "_version": "1.8.0",
  "sap.app": {
    "id": "BridgeManagement.reports",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.0.0" },
    "crossNavigation": {
      "inbounds": {
        "Reports-display": {
          "signature": { "parameters": {}, "additionalParameters": "allowed" },
          "semanticObject": "Reports",
          "action": "display",
          "title": "{{appTitle}}",
          "info": "{{appDescription}}",
          "subTitle": "{{appSubTitle}}",
          "icon": "sap-icon://bar-chart"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "deviceTypes": { "desktop": true, "phone": false, "tablet": true }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.f": {}
      }
    },
    "models": {
      "i18n": { "type": "sap.ui.model.resource.ResourceModel", "uri": "i18n/i18n.properties" }
    },
    "resources": { "css": [{ "uri": "css/style.css" }] },
    "rootView": {
      "viewName": "BridgeManagement.reports.view.Main",
      "type": "XML",
      "async": true,
      "id": "Main"
    },
    "contentDensities": { "compact": true, "cozy": false }
  },
  "sap.fiori": { "registrationIds": [], "archeType": "analytical" }
}
