{
  "welcomeFile": "/fiori-apps.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/fiori-apps\\.html$",
      "localDir": ".",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/appconfig/fioriSandboxConfig\\.json$",
      "target": "/launchpad/config",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/appconfig/(.*)$",
      "localDir": ".",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(map|dashboard|health|mass-upload)(.*)",
      "target": "/$1$2",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
