{
  "name": "BridgeManagement",
  "version": "1.3.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@cap-js/audit-logging": ">=0",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "helmet": "^8.1.0",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "jest": "^29.7.0"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest --testPathPattern=test/ --forceExit",
    "validate-build": "npx cds build --production && mbt build --mtar BridgeManagement-validate.mtar && echo 'BUILD OK'"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "private": true,
  "cds": {
    "query": {
      "limit": {
        "max": 1000,
        "default": 200
      }
    },
    "requires": {
      "[development]": {
        "auth": {
          "kind": "dummy"
        }
      },
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "application-logging": true
    }
  }
}
