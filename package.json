{
  "name": "BridgeManagement",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/audit-logging": "^1",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@sap/eslint-plugin-cds": "^4.2.1",
    "eslint": "^10.2.1",
    "jest": "^29.7.0"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest --testPathPattern=test/ --forceExit"
  },
  "engines": {
    "node": "20.x"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "private": true,
  "cds": {
    "query": {
      "limit": {
        "max": 10000,
        "default": 200,
        "reliablePaging": true
      }
    },
    "odata": {
      "batch_limit": 100
    },
    "requires": {
      "[development]": {
        "auth": {
          "kind": "dummy"
        }
      },
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "application-logging": true
    }
  }
}
