{
  "name": "BridgeManagement",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "@cap-js/audit-logging": ">=0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
  "start": "PORT=8008 cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "admin": {
              "password": "admin",
              "roles": [
                "admin"
              ]
            },
            "virinchy@live.com": {
              "password": "admin",
              "roles": [
                "admin"
              ]
            },
            "*": {
              "password": "admin",
              "roles": [
                "admin"
              ]
            }
          }
        }
      },
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "application-logging": true
    }
  }
}
